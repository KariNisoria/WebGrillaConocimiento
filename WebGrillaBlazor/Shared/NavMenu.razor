@using WebGrillaBlazor.Services
@using WebGrillaBlazor.DTOs
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">WebGrillaBlazor</a>
        
        <div class="d-flex align-items-center ms-auto">
            @if (AuthState.IsAuthenticated)
            {
                <!-- Información del usuario -->
                <div class="d-flex align-items-center text-white me-3">
                    <Icon Name="IconName.PersonCircle" class="me-2" />
                    <div class="d-none d-md-flex flex-column">
                        <div class="fw-semibold small">@AuthState.GetUserDisplayName()</div>
                        <small class="text-white-50 lh-1">@AuthState.CurrentUser?.NombreRol</small>
                    </div>
                </div>
            }
            else
            {
                <Button Color="ButtonColor.Primary" Size="ButtonSize.Small" Class="me-2" @onclick="GoToLogin">
                    <Icon Name="IconName.BoxArrowInRight" class="me-1" />
                    <span class="d-none d-sm-inline">Iniciar Sesión</span>
                    <span class="d-sm-none">Login</span>
                </Button>
            }
            
            <!-- Botón hamburguesa siempre al final -->
            <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        @if (AuthState.IsAuthenticated)
        {
            <!-- Separador -->
            <div class="nav-section-header px-3 mt-3 mb-2">
                <small class="text-muted fw-semibold">NAVEGACIÓN</small>
            </div>

            <!-- Inicio (anteriormente Dashboard) -->
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="index" Match="NavLinkMatch.All">
                    <span class="bi bi-house-door-fill" aria-hidden="true"></span> Inicio
                </NavLink>
            </div>

            <!-- Separador -->
            <div class="nav-section-header px-3 mt-3 mb-2">
                <small class="text-muted fw-semibold">GESTIÓN DE RECURSOS</small>
            </div>

            <!-- Recursos - Solo lectura para todos, escritura para admin/manager -->
            @if (AuthState.UserCanAccess("RECURSOS"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="recursos">
                        <span class="bi bi-people-fill" aria-hidden="true"></span> Recursos
                    </NavLink>
                </div>
            }

            <!-- Supervisión - Con permiso específico -->
            @if (AuthState.UserCanAccess("SUPERVISION") || AuthState.CurrentUser?.NombreRol == "Administrador")
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="supervision">
                        <span class="bi bi-diagram-3" aria-hidden="true"></span> Supervisión
                    </NavLink>
                </div>
            }

            <!-- Separador -->
            <div class="nav-section-header px-3 mt-3 mb-2">
                <small class="text-muted fw-semibold">GESTIÓN DE DATOS</small>
            </div>

            <!-- Roles - Solo admin y manager -->
            @if (AuthState.UserCanAccess("ROLES"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="roles">
                        <span class="bi bi-person-badge-fill" aria-hidden="true"></span> Roles
                    </NavLink>
                </div>
            }

            <!-- Equipos -->
            @if (AuthState.UserCanAccess("EQUIPOS"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="equipos">
                        <span class="bi bi-people-fill" aria-hidden="true"></span> Equipos
                    </NavLink>
                </div>
            }

            <!-- Clientes -->
            @if (AuthState.UserCanAccess("CLIENTES"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="clientes">
                        <span class="bi bi-building-fill" aria-hidden="true"></span> Clientes
                    </NavLink>
                </div>
            }

            <!-- Tipos de Documento -->
            @if (AuthState.UserCanAccess("TIPOS_DOCUMENTO"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="tipos">
                        <span class="bi bi-card-text" aria-hidden="true"></span> Tipos Documento
                    </NavLink>
                </div>
            }

            <!-- Separador -->
            <div class="nav-section-header px-3 mt-3 mb-2">
                <small class="text-muted fw-semibold">CONOCIMIENTOS</small>
            </div>

            <!-- Temas -->
            @if (AuthState.UserCanAccess("TEMAS"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="temas">
                        <span class="bi bi-journal-bookmark-fill" aria-hidden="true"></span> Temas
                    </NavLink>
                </div>
            }

            <!-- Subtemas -->
            @if (AuthState.UserCanAccess("SUBTEMAS"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="subtemas">
                        <span class="bi bi-journal-text" aria-hidden="true"></span> Subtemas
                    </NavLink>
                </div>
            }

            <!-- Grillas -->
            @if (AuthState.UserCanAccess("GRILLAS"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="grillas">
                        <span class="bi bi-grid-3x3-gap-fill" aria-hidden="true"></span> Grillas
                    </NavLink>
                </div>
            }

            <!-- Separador -->
            <div class="nav-section-header px-3 mt-3 mb-2">
                <small class="text-muted fw-semibold">EVALUACIONES</small>
            </div>

            <!-- Evaluaciones -->
            @if (AuthState.CanAccessEvaluations())
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="evaluaciones">
                        <span class="bi bi-clipboard-check-fill" aria-hidden="true"></span> Evaluaciones
                    </NavLink>
                </div>
            }

            <!-- Evaluaciones Globales -->
            @if (AuthState.UserCanAccess("EVALUACIONES_GLOBALES"))
            {
                <div class="nav-item px-3">
                    <NavLink class="nav-link" href="evaluaciones-globales">
                        <span class="bi bi-bar-chart-fill" aria-hidden="true"></span> Evaluaciones Globales
                    </NavLink>
                </div>
            }

            <!-- Separador - Solo para administradores -->
            @if (AuthState.UserHasPermission("PERMISOS_ADMIN") || AuthState.UserHasPermission("CONFIGURACION_SISTEMA") || AuthState.CurrentUser?.NombreRol == "Administrador")
            {
                <div class="nav-section-header px-3 mt-3 mb-2">
                    <small class="text-muted fw-semibold">ADMINISTRACIÓN</small>
                </div>

                <!-- Gestión de Permisos -->
                @if (AuthState.UserHasPermission("PERMISOS_ADMIN") || AuthState.CurrentUser?.NombreRol == "Administrador")
                {
                    <div class="nav-item px-3">
                        <NavLink class="nav-link" href="permisos">
                            <span class="bi bi-shield-check" aria-hidden="true"></span> Permisos
                        </NavLink>
                    </div>
                }
            }

            <!-- Separador para información del usuario en móvil -->
            <div class="nav-section-header px-3 mt-4 mb-2 d-md-none">
                <small class="text-muted fw-semibold">USUARIO ACTUAL</small>
            </div>
            
            <div class="nav-item px-3 d-md-none">
                <div class="nav-link-static">
                    <Icon Name="IconName.PersonCircle" class="me-2" />
                    <div>
                        <div class="fw-semibold">@AuthState.GetUserDisplayName()</div>
                        <small class="text-muted">@AuthState.CurrentUser?.NombreRol</small>
                    </div>
                </div>
            </div>

            <!-- Separador y botón de cerrar sesión AL FINAL -->
            <div class="nav-section-header px-3 mt-4 mb-2">
                <small class="text-muted fw-semibold">SESIÓN</small>
            </div>
            
            <div class="nav-item px-3 pb-3">
                <Button Color="ButtonColor.Danger" 
                        Size="ButtonSize.Small" 
                        Class="w-100"
                        @onclick="HandleLogout">
                    <Icon Name="IconName.BoxArrowRight" class="me-1" />
                    Cerrar Sesión
                </Button>
            </div>
        }
        else
        {
            <!-- Si no está autenticado, mostrar solo el botón de login -->
            <div class="nav-item px-3 mt-3">
                <Button Color="ButtonColor.Primary" @onclick="GoToLogin">
                    <Icon Name="IconName.BoxArrowInRight" class="me-2" />
                    Iniciar Sesión
                </Button>
            </div>
        }
    </nav>
</div>

<style>
    .nav-section-header {
        border-bottom: 1px solid rgba(255,255,255,0.1);
        padding-bottom: 0.5rem;
    }
    
    .nav-link-static {
        display: block;
        padding: 0.5rem 1rem;
        color: rgba(255,255,255,0.8);
        text-decoration: none;
        border-radius: 0.375rem;
        background: rgba(255,255,255,0.05);
    }
    
    .top-row {
        background: linear-gradient(45deg, #1b6ec2, #0d6efd) !important;
        min-height: 3.5rem;
    }
    
    /* Mejorar el espaciado del botón toggler */
    .navbar-toggler {
        border: 1px solid rgba(255,255,255,0.25);
        padding: 0.375rem 0.5rem;
        margin-left: 0.5rem;
    }
    
    .navbar-toggler:focus {
        box-shadow: 0 0 0 0.25rem rgba(255,255,255,0.25);
    }
    
    /* Asegurar que el contenedor superior use todo el espacio disponible */
    .top-row .container-fluid {
        display: flex;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        padding-right: 1rem;
        padding-left: 1rem;
    }
    
    /* Mejorar la presentación del texto del usuario */
    .top-row .fw-semibold.small {
        font-size: 0.85rem;
        line-height: 1.2;
    }
    
    /* Estilo especial para el botón de cerrar sesión */
    .nav-item .btn-danger {
        background: linear-gradient(135deg, #dc3545, #c82333);
        border: none;
        box-shadow: 0 2px 4px rgba(220, 53, 69, 0.3);
        transition: all 0.2s ease;
    }
    
    .nav-item .btn-danger:hover {
        background: linear-gradient(135deg, #c82333, #a71e2a);
        box-shadow: 0 4px 8px rgba(220, 53, 69, 0.4);
        transform: translateY(-1px);
    }
    
    /* Responsive adjustments */
    @@media (max-width: 767.98px) {
        .top-row {
            padding-left: 1rem;
            padding-right: 0.5rem;
        }
        
        .navbar-brand {
            font-size: 1rem;
        }
    }
    
    @@media (max-width: 575.98px) {
        .top-row .me-3 {
            margin-right: 0.5rem !important;
        }
        
        .top-row .me-2 {
            margin-right: 0.25rem !important;
        }
    }
</style>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("🧭 NavMenu: Inicializando...");
        
        // Solo suscribirse a eventos, NO inicializar AuthState
        // El AppStateInitializer se encarga de la inicialización
        AuthState.OnUserChanged += OnAuthStateChanged;
        AuthState.OnLogout += OnLogoutStateChanged;

        Console.WriteLine($"🧭 NavMenu: Estado actual - Auth: {AuthState.IsAuthenticated}");
    }

    private void OnAuthStateChanged(RecursoSessionDTO? user)
    {
        Console.WriteLine($"🧭 NavMenu: Usuario cambió a {user?.NombreCompleto ?? "null"}");
        InvokeAsync(() => StateHasChanged());
    }

    private void OnLogoutStateChanged()
    {
        Console.WriteLine("🧭 NavMenu: Evento de logout recibido");
        InvokeAsync(() => StateHasChanged());
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void GoToLogin()
    {
        Console.WriteLine("🧭 NavMenu: Navegando a login");
        Navigation.NavigateTo("/login", forceLoad: false);
    }

    private async Task HandleLogout()
    {
        Console.WriteLine("🧭 NavMenu: Iniciando logout");
        await AuthState.LogoutAsync();
        Console.WriteLine("🧭 NavMenu: Logout completado, navegando a login");
        Navigation.NavigateTo("/login", forceLoad: false);
    }

    public void Dispose()
    {
        AuthState.OnUserChanged -= OnAuthStateChanged;
        AuthState.OnLogout -= OnLogoutStateChanged;
    }
}
