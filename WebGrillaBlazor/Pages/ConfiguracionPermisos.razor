    private void CargarConsultasSQL()
    {
        consultasSQL = new Dictionary<string, string>
        {
            {
                "Ver todos los roles y permisos",
                @"SELECT 
    r.Nombre as Rol,
    rp.CodigoPermiso,
    rp.Descripcion,
    rp.Activo
FROM RolPermisos rp
INNER JOIN Roles r ON r.IdRol = rp.IdRol
ORDER BY r.Nombre, rp.CodigoPermiso;"
            },
            {
                "Permisos por rol específico",
                @"SELECT 
    rp.CodigoPermiso,
    rp.Descripcion,
    rp.Activo
FROM RolPermisos rp
INNER JOIN Roles r ON r.IdRol = rp.IdRol
WHERE r.Nombre = 'Administrador'  -- Cambiar por el rol deseado
  AND rp.Activo = 1
ORDER BY rp.CodigoPermiso;"
            },
            {
                "Usuarios y sus roles",
                @"SELECT 
    r.Nombre,
    r.Apellido,
    r.CorreoElectronico,
    rol.Nombre as Rol,
    COUNT(rp.IdRolPermiso) as TotalPermisos
FROM Recursos r
INNER JOIN Roles rol ON r.IdRol = rol.IdRol
LEFT JOIN RolPermisos rp ON rol.IdRol = rp.IdRol AND rp.Activo = 1
GROUP BY r.Nombre, r.Apellido, r.CorreoElectronico, rol.Nombre
ORDER BY rol.Nombre, r.Apellido;"
            },
            {
                "Contar permisos por rol",
                @"SELECT 
    r.Nombre as Rol,
    COUNT(rp.IdRolPermiso) as TotalPermisos,
    COUNT(CASE WHEN rp.Activo = 1 THEN 1 END) as PermisosActivos
FROM Roles r
LEFT JOIN RolPermisos rp ON r.IdRol = rp.IdRol
GROUP BY r.Nombre
ORDER BY TotalPermisos DESC;"
            },
            {
                "Agregar permiso a rol",
                @"INSERT INTO RolPermisos (IdRol, CodigoPermiso, Descripcion, Activo)
VALUES (
    (SELECT IdRol FROM Roles WHERE Nombre = 'Manager'),  -- Cambiar rol
    'NUEVO_MODULO_READ',                                  -- Cambiar permiso
    'Descripción del permiso',                           -- Cambiar descripción
    1
);"
            },
            {
                "Desactivar permiso",
                @"UPDATE RolPermisos 
SET Activo = 0
WHERE IdRol = (SELECT IdRol FROM Roles WHERE Nombre = 'Evaluador')  -- Cambiar rol
  AND CodigoPermiso = 'RECURSOS_WRITE';                              -- Cambiar permiso"
            }
        };
    }

