    private void TogglePermisoParaAsociacion(string permiso, bool seleccionado)
    {
        if (seleccionado)
            permisosSeleccionadosAsociacion.Add(permiso);
        else
            permisosSeleccionadosAsociacion.Remove(permiso);
    }

    private void AsociarPermisoARuta()
    {
        if (string.IsNullOrEmpty(rutaSeleccionadaParaAsociacion) || !permisosSeleccionadosAsociacion.Any())
            return;

        // Actualizar las asociaciones
        asociacionesRutaPermiso[rutaSeleccionadaParaAsociacion] = permisosSeleccionadosAsociacion.ToList();

        // Limpiar selección
        rutaSeleccionadaParaAsociacion = string.Empty;
        permisosSeleccionadosAsociacion.Clear();

        MostrarToast("Asociación guardada correctamente", "success");
        StateHasChanged();
    }

    private void MostrarConsultaSQL(string nombreConsulta)
    {
        if (consultasSQL.ContainsKey(nombreConsulta))
        {
            consultaSQLSeleccionada = consultasSQL[nombreConsulta];
            StateHasChanged();
        }
    }

    private async Task CopiarConsulta()
    {
        if (!string.IsNullOrEmpty(consultaSQLSeleccionada))
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", consultaSQLSeleccionada);
            MostrarToast("Consulta copiada al portapapeles", "success");
        }
    }

    private string GetModuleColor(string modulo)
    {
        return modulo switch
        {
            "RECURSOS" => "primary",
            "GRILLAS" => "success",
            "EVALUACIONES" => "warning",
            "TEMAS" => "info",
            "CLIENTES" => "secondary",
            "AUTH" => "dark",
            "DASHBOARD" => "primary",
            "EQUIPOS" => "info",
            "ROLES" => "secondary",
            "PERMISOS" => "danger",
            _ => "light"
        };
    }

    private string GetRoleColor(string rol)
    {
        return rol switch
        {
            "Administrador" => "danger",
            "Manager" => "warning",
            "Evaluador" => "info",
            "Desarrollador" => "secondary",
            _ => "primary"
        };
    }

    private void MostrarToast(string mensaje, string tipo)
    {
        mensajeToast = mensaje;
        tipoToast = tipo;
        mostrarToast = true;
        Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { mostrarToast = false; StateHasChanged(); }));
    }
