@page "/admin/permisos-roles"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.Services
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Configuración de Permisos y Roles</PageTitle>

<WebGrillaBlazor.Components.AuthorizeView RedirectToLogin="true">
    @if (!AuthState.UserHasPermission("PERMISOS_ADMIN"))
    {
        <div class="alert alert-danger">
            <h4 class="alert-heading">?? Acceso Denegado</h4>
            <p>No tienes permisos para administrar los permisos del sistema.</p>
            <hr>
            <p class="mb-0">Contacta con un administrador si necesitas acceso a esta funcionalidad.</p>
        </div>
        return;
    }

    <div class="container-fluid">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 mb-0">
                            <Icon Name="IconName.ShieldLock" class="me-2 text-primary" />
                            Configuración de Permisos y Roles
                        </h1>
                        <p class="text-muted mt-1">Gestiona roles, permisos y su asociación con las rutas del sistema</p>
                    </div>
                    <div>
                        <button class="btn btn-success me-2" @onclick="CargarDatos">
                            <Icon Name="IconName.ArrowClockwise" class="me-1" />
                            Actualizar
                        </button>
                        <button class="btn btn-outline-primary" @onclick="() => mostrarAyuda = !mostrarAyuda">
                            <Icon Name="IconName.QuestionCircle" class="me-1" />
                            Ayuda
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel de ayuda -->
        @if (mostrarAyuda)
        {
            <div class="row mb-4">
                <div class="col-12">
                    <div class="alert alert-info">
                        <h6 class="alert-heading">
                            <Icon Name="IconName.InfoCircle" class="me-2" />
                            Guía de Configuración de Permisos
                        </h6>
                        <div class="row">
                            <div class="col-md-4">
                                <h6>Tipos de Permisos:</h6>
                                <ul class="small">
                                    <li><code>READ</code> - Ver/Consultar</li>
                                    <li><code>WRITE</code> - Crear/Editar</li>
                                    <li><code>DELETE</code> - Eliminar</li>
                                    <li><code>ADMIN</code> - Administrar</li>
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <h6>Módulos del Sistema:</h6>
                                <ul class="small">
                                    <li>RECURSOS - Gestión de personas</li>
                                    <li>GRILLAS - Grillas de conocimiento</li>
                                    <li>EVALUACIONES - Proceso de evaluación</li>
                                    <li>TEMAS - Temas y subtemas</li>
                                    <li>CLIENTES - Gestión de clientes</li>
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <h6>Formato de Permisos:</h6>
                                <p class="small"><code>MODULO_ACCION</code></p>
                                <p class="small">Ejemplo: <code>RECURSOS_READ</code></p>
                                <p class="small">Permite consultar la página de recursos</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Estado del sistema -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card border-primary">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Shield" Size="IconSize.x2" class="text-primary mb-2" />
                        <h4 class="text-primary">@totalRoles</h4>
                        <p class="mb-0 small">Roles Configurados</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-success">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Key" Size="IconSize.x2" class="text-success mb-2" />
                        <h4 class="text-success">@totalPermisos</h4>
                        <p class="mb-0 small">Permisos Únicos</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-info">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Diagram3" Size="IconSize.x2" class="text-info mb-2" />
                        <h4 class="text-info">@rutasDisponibles.Count</h4>
                        <p class="mb-0 small">Rutas del Sistema</p>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card border-warning">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Link" Size="IconSize.x2" class="text-warning mb-2" />
                        <h4 class="text-warning">@asociacionesRutaPermiso.Count</h4>
                        <p class="mb-0 small">Rutas Protegidas</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tabs principales -->
        <ul class="nav nav-tabs mb-4" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link @(tabActiva == "rutas" ? "active" : "")" 
                        @onclick='() => CambiarTab("rutas")' 
                        type="button">
                    <Icon Name="IconName.Globe" class="me-1" /> Rutas y Permisos
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(tabActiva == "roles" ? "active" : "")" 
                        @onclick='() => CambiarTab("roles")' 
                        type="button">
                    <Icon Name="IconName.People" class="me-1" /> Roles y Permisos
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(tabActiva == "matriz" ? "active" : "")" 
                        @onclick='() => CambiarTab("matriz")' 
                        type="button">
                    <Icon Name="IconName.Grid" class="me-1" /> Matriz de Permisos
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link @(tabActiva == "consultas" ? "active" : "")" 
                        @onclick='() => CambiarTab("consultas")' 
                        type="button">
                    <Icon Name="IconName.Code" class="me-1" /> Consultas SQL
                </button>
            </li>
        </ul>

        <!-- Contenido del tab Rutas y Permisos -->
        @if (tabActiva == "rutas")
        {
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-primary text-white">
                            <h6 class="mb-0">
                                <Icon Name="IconName.Globe" class="me-2" />
                                Rutas Disponibles del Sistema
                            </h6>
                        </div>
                        <div class="card-body p-0">
                            <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
                                <table class="table table-sm table-hover mb-0">
                                    <thead class="table-light sticky-top">
                                        <tr>
                                            <th>Ruta</th>
                                            <th>Descripción</th>
                                            <th>Módulo</th>
                                            <th>Estado</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var ruta in rutasDisponibles.OrderBy(r => r.Modulo).ThenBy(r => r.Ruta))
                                        {
                                            <tr class="@(asociacionesRutaPermiso.ContainsKey(ruta.Ruta) ? "table-success" : "table-warning")">
                                                <td>
                                                    <code>@ruta.Ruta</code>
                                                </td>
                                                <td>@ruta.Descripcion</td>
                                                <td>
                                                    <span class="badge bg-@GetModuleColor(ruta.Modulo)">@ruta.Modulo</span>
                                                </td>
                                                <td>
                                                    @if (asociacionesRutaPermiso.ContainsKey(ruta.Ruta))
                                                    {
                                                        <span class="badge bg-success">
                                                            <Icon Name="IconName.ShieldCheck" /> Protegida
                                                        </span>
                                                        <small class="d-block text-muted">
                                                            @string.Join(", ", asociacionesRutaPermiso[ruta.Ruta])
                                                        </small>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-warning text-dark">
                                                            <Icon Name="IconName.ExclamationTriangle" /> Sin protección
                                                        </span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-success text-white">
                            <h6 class="mb-0">
                                <Icon Name="IconName.PlusCircle" class="me-2" />
                                Asociar Permiso a Ruta
                            </h6>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <label for="rutaSeleccionada" class="form-label">Seleccionar Ruta:</label>
                                <select class="form-select" id="rutaSeleccionada" @bind="rutaSeleccionadaParaAsociacion">
                                    <option value="">Seleccionar ruta...</option>
                                    @foreach (var ruta in rutasDisponibles.OrderBy(r => r.Ruta))
                                    {
                                        <option value="@ruta.Ruta">@ruta.Ruta - @ruta.Descripcion</option>
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label for="permisoAsociacion" class="form-label">Permisos Requeridos:</label>
                                <div class="row">
                                    @foreach (var permiso in permisosDefinidos.OrderBy(p => p))
                                    {
                                        <div class="col-md-6 mb-2">
                                            <div class="form-check">
                                                <input class="form-check-input" 
                                                       type="checkbox" 
                                                       id="permiso_@permiso.Replace("_", "")"
                                                       @onchange="@(e => TogglePermisoParaAsociacion(permiso, (bool)e.Value!))" 
                                                       checked="@permisosSeleccionadosAsociacion.Contains(permiso)">
                                                <label class="form-check-label small" for="permiso_@permiso.Replace("_", "")">
                                                    <code>@permiso</code>
                                                </label>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>

                            <div class="d-grid gap-2">
                                <button class="btn btn-success" 
                                        @onclick="AsociarPermisoARuta"
                                        disabled="@(string.IsNullOrEmpty(rutaSeleccionadaParaAsociacion) || !permisosSeleccionadosAsociacion.Any())">
                                    <Icon Name="IconName.Link" class="me-1" />
                                    Asociar Permisos a Ruta
                                </button>
                            </div>

                            <!-- Vista previa de la asociación actual -->
                            @if (!string.IsNullOrEmpty(rutaSeleccionadaParaAsociacion))
                            {
                                <div class="mt-3 p-3 bg-light rounded">
                                    <h6>Vista previa:</h6>
                                    <p class="mb-1"><strong>Ruta:</strong> <code>@rutaSeleccionadaParaAsociacion</code></p>
                                    <p class="mb-1"><strong>Permisos actuales:</strong></p>
                                    @if (asociacionesRutaPermiso.ContainsKey(rutaSeleccionadaParaAsociacion))
                                    {
                                        @foreach (var permiso in asociacionesRutaPermiso[rutaSeleccionadaParaAsociacion])
                                        {
                                            <span class="badge bg-primary me-1">@permiso</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-muted">Sin permisos asociados</span>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Contenido del tab Roles y Permisos -->
        @if (tabActiva == "roles")
        {
            <div class="row">
                @foreach (var rol in rolesConPermisos.OrderBy(r => r.NombreRol))
                {
                    <div class="col-md-6 col-lg-4 mb-4">
                        <div class="card h-100">
                            <div class="card-header bg-@GetRoleColor(rol.NombreRol) text-white">
                                <h6 class="mb-0">
                                    <Icon Name="IconName.PersonBadge" class="me-2" />
                                    @rol.NombreRol
                                </h6>
                                <small>@rol.TotalPermisos permisos asignados</small>
                            </div>
                            <div class="card-body p-0">
                                <div class="list-group list-group-flush" style="max-height: 300px; overflow-y: auto;">
                                    @if (rol.Permisos.Any())
                                    {
                                        @foreach (var grupo in rol.Permisos.GroupBy(p => p.Split('_')[0]).OrderBy(g => g.Key))
                                        {
                                            <div class="list-group-item">
                                                <div class="fw-bold text-primary small">@grupo.Key</div>
                                                @foreach (var permiso in grupo.OrderBy(p => p))
                                                {
                                                    <span class="badge bg-outline-primary me-1 small">@permiso.Replace(grupo.Key + "_", "")</span>
                                                }
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="list-group-item text-muted text-center">
                                            <Icon Name="IconName.ExclamationTriangle" />
                                            Sin permisos asignados
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <!-- Contenido del tab Matriz de Permisos -->
        @if (tabActiva == "matriz")
        {
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">
                        <Icon Name="IconName.Grid" class="me-2" />
                        Matriz de Permisos - Roles vs Módulos
                    </h6>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-sm table-bordered mb-0">
                            <thead class="table-dark">
                                <tr>
                                    <th class="text-center" style="width: 150px;">Rol \ Módulo</th>
                                    @foreach (var modulo in modulos.OrderBy(m => m))
                                    {
                                        <th class="text-center" style="writing-mode: vertical-lr; text-orientation: mixed;">
                                            @modulo
                                        </th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rol in rolesConPermisos.OrderBy(r => r.NombreRol))
                                {
                                    <tr>
                                        <td class="fw-bold text-@GetRoleColor(rol.NombreRol)">@rol.NombreRol</td>
                                        @foreach (var modulo in modulos.OrderBy(m => m))
                                        {
                                            <td class="text-center">
                                                @{
                                                    var permisosModulo = rol.Permisos.Where(p => p.StartsWith(modulo + "_")).ToList();
                                                }
                                                @if (permisosModulo.Any())
                                                {
                                                    <div class="d-flex flex-wrap justify-content-center gap-1">
                                                        @if (permisosModulo.Any(p => p.EndsWith("_READ")))
                                                        {
                                                            <span class="badge bg-info" title="Lectura">R</span>
                                                        }
                                                        @if (permisosModulo.Any(p => p.EndsWith("_WRITE")))
                                                        {
                                                            <span class="badge bg-warning" title="Escritura">W</span>
                                                        }
                                                        @if (permisosModulo.Any(p => p.EndsWith("_DELETE")))
                                                        {
                                                            <span class="badge bg-danger" title="Eliminar">D</span>
                                                        }
                                                        @if (permisosModulo.Any(p => p.EndsWith("_ADMIN")))
                                                        {
                                                            <span class="badge bg-dark" title="Admin">A</span>
                                                        }
                                                        @if (permisosModulo.Any(p => !p.EndsWith("_READ") && !p.EndsWith("_WRITE") && !p.EndsWith("_DELETE") && !p.EndsWith("_ADMIN")))
                                                        {
                                                            <span class="badge bg-secondary" title="Otros">+</span>
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
                <div class="card-footer">
                    <small class="text-muted">
                        <strong>Leyenda:</strong>
                        <span class="badge bg-info ms-2">R</span> Lectura
                        <span class="badge bg-warning ms-1">W</span> Escritura
                        <span class="badge bg-danger ms-1">D</span> Eliminar
                        <span class="badge bg-dark ms-1">A</span> Admin
                        <span class="badge bg-secondary ms-1">+</span> Otros
                    </small>
                </div>
            </div>
        }

        <!-- Contenido del tab Consultas SQL -->
        @if (tabActiva == "consultas")
        {
            <div class="row">
                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header bg-dark text-white">
                            <h6 class="mb-0">
                                <Icon Name="IconName.Code" class="me-2" />
                                Consultas SQL Predefinidas
                            </h6>
                        </div>
                        <div class="card-body">
                            @foreach (var consulta in consultasSQL)
                            {
                                <div class="mb-3">
                                    <button class="btn btn-outline-primary btn-sm" 
                                            @onclick="() => MostrarConsultaSQL(consulta.Key)">
                                        <Icon Name="IconName.Play" class="me-1" />
                                        @consulta.Key
                                    </button>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="card">
                        <div class="card-header">
                            <h6 class="mb-0">
                                <Icon Name="IconName.Terminal" class="me-2" />
                                Consulta SQL Seleccionada
                            </h6>
                        </div>
                        <div class="card-body">
                            @if (!string.IsNullOrEmpty(consultaSQLSeleccionada))
                            {
                                <div class="bg-dark text-light p-3 rounded">
                                    <pre><code>@consultaSQLSeleccionada</code></pre>
                                </div>
                                <div class="mt-3">
                                    <button class="btn btn-success btn-sm" @onclick="CopiarConsulta">
                                        <Icon Name="IconName.Clipboard" class="me-1" />
                                        Copiar al Portapapeles
                                    </button>
                                </div>
                            }
                            else
                            {
                                <p class="text-muted text-center py-4">
                                    Selecciona una consulta de la lista de la izquierda
                                </p>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- Toast de confirmación -->
    @if (mostrarToast)
    {
        <div class="toast align-items-center @(tipoToast == "success" ? "text-bg-success" : "text-bg-danger") border-0 show position-fixed bottom-0 end-0 m-4" 
             role="alert" aria-live="assertive" aria-atomic="true" style="z-index:9999;">
            <div class="d-flex">
                <div class="toast-body">
                    @mensajeToast
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="()=>mostrarToast=false" aria-label="Close"></button>
            </div>
        </div>
    }
</WebGrillaBlazor.Components.AuthorizeView>

@code {
    // Estado de la UI
    private string tabActiva = "rutas";
    private bool mostrarAyuda = false;
    private bool mostrarToast = false;
    private string mensajeToast = string.Empty;
    private string tipoToast = "success";

    // Datos del sistema
    private int totalRoles = 0;
    private int totalPermisos = 0;
    private List<RolConPermisos> rolesConPermisos = new();
    private List<RutaInfo> rutasDisponibles = new();
    private Dictionary<string, List<string>> asociacionesRutaPermiso = new();
    private List<string> permisosDefinidos = new();
    private List<string> modulos = new();

    // Formulario de asociación
    private string rutaSeleccionadaParaAsociacion = string.Empty;
    private HashSet<string> permisosSeleccionadosAsociacion = new();

    // Consultas SQL
    private Dictionary<string, string> consultasSQL = new();
    private string consultaSQLSeleccionada = string.Empty;

    // Clases para los datos
    public class RolConPermisos
    {
        public string NombreRol { get; set; } = string.Empty;
        public List<string> Permisos { get; set; } = new();
        public int TotalPermisos => Permisos.Count;
    }

    public class RutaInfo
    {
        public string Ruta { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public string Modulo { get; set; } = string.Empty;
        public bool EsPublica { get; set; } = false;
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            await Task.Delay(100); // Simular carga de datos

            // Cargar rutas del sistema
            CargarRutasDelSistema();

            // Cargar permisos definidos
            CargarPermisosDefinidos();

            // Cargar roles con permisos (esto vendría de la base de datos)
            CargarRolesConPermisos();

            // Cargar asociaciones ruta-permiso
            CargarAsociacionesRutaPermiso();

            // Cargar consultas SQL predefinidas
            CargarConsultasSQL();

            // Calcular estadísticas
            CalcularEstadisticas();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            MostrarToast($"Error al cargar datos: {ex.Message}", "error");
        }
    }

    private void CargarRutasDelSistema()
    {
        rutasDisponibles = new List<RutaInfo>
        {
            // Rutas públicas
            new() { Ruta = "/", Descripcion = "Login del Sistema", Modulo = "AUTH", EsPublica = true },
            new() { Ruta = "/login", Descripcion = "Página de Login", Modulo = "AUTH", EsPublica = true },
            new() { Ruta = "/index", Descripcion = "Dashboard Principal", Modulo = "DASHBOARD", EsPublica = false },
            new() { Ruta = "/dashboard", Descripcion = "Panel de Control", Modulo = "DASHBOARD", EsPublica = false },

            // Gestión de Recursos
            new() { Ruta = "/recursos", Descripcion = "Lista de Recursos", Modulo = "RECURSOS", EsPublica = false },
            new() { Ruta = "/recursos/crear", Descripcion = "Crear Recurso", Modulo = "RECURSOS", EsPublica = false },
            new() { Ruta = "/recursos/editar", Descripcion = "Editar Recurso", Modulo = "RECURSOS", EsPublica = false },

            // Gestión de Grillas
            new() { Ruta = "/grillas", Descripcion = "Lista de Grillas", Modulo = "GRILLAS", EsPublica = false },
            new() { Ruta = "/grillas/{id}/temas", Descripcion = "Temas de Grilla", Modulo = "GRILLAS", EsPublica = false },
            new() { Ruta = "/grilla-temas", Descripcion = "Gestión de Temas", Modulo = "GRILLAS", EsPublica = false },
            new() { Ruta = "/grilla-subtemas", Descripcion = "Gestión de Subtemas", Modulo = "GRILLAS", EsPublica = false },

            // Gestión de Evaluaciones
            new() { Ruta = "/evaluaciones", Descripcion = "Lista de Evaluaciones", Modulo = "EVALUACIONES", EsPublica = false },
            new() { Ruta = "/evaluaciones-globales", Descripcion = "Evaluaciones Globales", Modulo = "EVALUACIONES", EsPublica = false },
            new() { Ruta = "/evaluacion/{id}/recurso/{idRecurso}", Descripcion = "Realizar Evaluación", Modulo = "EVALUACIONES", EsPublica = false },

            // Gestión de Contenido
            new() { Ruta = "/temas", Descripcion = "Lista de Temas", Modulo = "TEMAS", EsPublica = false },
            new() { Ruta = "/clientes", Descripcion = "Lista de Clientes", Modulo = "CLIENTES", EsPublica = false },
            new() { Ruta = "/tipos", Descripcion = "Tipos de Documento", Modulo = "TIPOS_DOCUMENTO", EsPublica = false },

            // Organización
            new() { Ruta = "/equipos", Descripcion = "Equipos de Desarrollo", Modulo = "EQUIPOS", EsPublica = false },
            new() { Ruta = "/roles", Descripcion = "Gestión de Roles", Modulo = "ROLES", EsPublica = false },

            // Administración
