@page "/admin/permisos-roles"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.Services
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Configuración de Roles y Permisos</PageTitle>

<WebGrillaBlazor.Components.AuthorizeView RedirectToLogin="true">
    @if (!AuthState.UserHasPermission("PERMISOS_ADMIN"))
    {
        <div class="alert alert-danger">
            <h4 class="alert-heading">?? Acceso Denegado</h4>
            <p>No tienes permisos para administrar los permisos del sistema.</p>
            <hr>
            <p class="mb-0">Contacta con un administrador si necesitas acceso a esta funcionalidad.</p>
        </div>
        return;
    }

    <div class="container-fluid">
        <!-- Header -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h1 class="h3 mb-0">
                            <Icon Name="IconName.ShieldLock" class="me-2 text-primary" />
                            Configuración de Roles y Permisos
                        </h1>
                        <p class="text-muted mt-1">Gestiona los roles del sistema y sus permisos asociados</p>
                    </div>
                    <div>
                        <button class="btn btn-success me-2" @onclick="CargarDatos">
                            <Icon Name="IconName.ArrowClockwise" class="me-1" />
                            Actualizar
                        </button>
                        <button class="btn btn-outline-primary" @onclick="() => mostrarAyuda = !mostrarAyuda">
                            <Icon Name="IconName.QuestionCircle" class="me-1" />
                            Ayuda
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Panel de ayuda -->
        @if (mostrarAyuda)
        {
            <div class="row mb-4">
                <div class="col-12">
                    <div class="alert alert-info">
                        <h6 class="alert-heading">
                            <Icon Name="IconName.InfoCircle" class="me-2" />
                            Guía de Configuración de Permisos
                        </h6>
                        <div class="row">
                            <div class="col-md-4">
                                <h6>Tipos de Permisos:</h6>
                                <ul class="small">
                                    <li><code>READ</code> - Ver/Consultar</li>
                                    <li><code>WRITE</code> - Crear/Editar</li>
                                    <li><code>DELETE</code> - Eliminar</li>
                                    <li><code>ADMIN</code> - Administrar</li>
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <h6>Módulos del Sistema:</h6>
                                <ul class="small">
                                    <li>RECURSOS - Gestión de personas</li>
                                    <li>GRILLAS - Grillas de conocimiento</li>
                                    <li>EVALUACIONES - Proceso de evaluación</li>
                                    <li>TEMAS - Temas y subtemas</li>
                                    <li>CLIENTES - Gestión de clientes</li>
                                </ul>
                            </div>
                            <div class="col-md-4">
                                <h6>Formato de Permisos:</h6>
                                <p class="small"><code>MODULO_ACCION</code></p>
                                <p class="small">Ejemplo: <code>RECURSOS_READ</code></p>
                                <p class="small">Permite consultar la página de recursos</p>
                                <p class="small text-warning">
                                    <Icon Name="IconName.ExclamationTriangle" class="me-1" />
                                    Los permisos se configuran directamente en la base de datos
                                </p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Estado del sistema -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card border-primary">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Shield" Size="IconSize.x2" class="text-primary mb-2" />
                        <h4 class="text-primary">@totalRoles</h4>
                        <p class="mb-0 small">Roles Configurados</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-success">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Key" Size="IconSize.x2" class="text-success mb-2" />
                        <h4 class="text-success">@totalPermisos</h4>
                        <p class="mb-0 small">Permisos Únicos</p>
                    </div>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card border-info">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Database" Size="IconSize.x2" class="text-info mb-2" />
                        <h4 class="text-info">BD</h4>
                        <p class="mb-0 small">Datos desde Base de Datos</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Información importante sobre la configuración -->
        <div class="row mb-4">
            <div class="col-12">
                <div class="alert alert-warning">
                    <h6 class="alert-heading">
                        <Icon Name="IconName.Database" class="me-2" />
                        Configuración de Permisos
                    </h6>
                    <p class="mb-2">
                        Los permisos mostrados a continuación reflejan la configuración actual de la base de datos. 
                        Para modificar permisos, utilice las siguientes opciones:
                    </p>
                    <div class="d-flex gap-2 flex-wrap">
                        <span class="badge bg-primary">
                            <Icon Name="IconName.Database" class="me-1" />
                            Scripts SQL directos
                        </span>
                        <span class="badge bg-success">
                            <Icon Name="IconName.Terminal" class="me-1" />
                            Gestión por código
                        </span>
                        <span class="badge bg-info">
                            <Icon Name="IconName.Tools" class="me-1" />
                            Herramientas de BD
                        </span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Contenido principal: Roles y Permisos -->
        <div class="row">
            <div class="col-12 mb-3">
                <h4>
                    <Icon Name="IconName.People" class="me-2 text-primary" />
                    Roles y Permisos del Sistema
                </h4>
                <p class="text-muted">Vista de los roles configurados en la base de datos y sus permisos asociados</p>
            </div>
        </div>

        <div class="row">
            @foreach (var rol in rolesConPermisos.OrderBy(r => r.NombreRol))
            {
                <div class="col-md-6 col-lg-4 mb-4">
                    <div class="card h-100">
                        <div class="card-header bg-@GetRoleColor(rol.NombreRol) text-white">
                            <h6 class="mb-0">
                                <Icon Name="IconName.PersonBadge" class="me-2" />
                                @rol.NombreRol
                            </h6>
                            <small>@rol.TotalPermisos permisos asignados</small>
                        </div>
                        <div class="card-body p-0">
                            <div class="list-group list-group-flush" style="max-height: 400px; overflow-y: auto;">
                                @if (rol.Permisos.Any())
                                {
                                    @foreach (var grupo in rol.Permisos.GroupBy(p => p.Split('_')[0]).OrderBy(g => g.Key))
                                    {
                                        <div class="list-group-item">
                                            <div class="d-flex justify-content-between align-items-start">
                                                <div>
                                                    <div class="fw-bold text-primary small mb-2">
                                                        <Icon Name="IconName.FolderFill" class="me-1" />
                                                        @grupo.Key
                                                    </div>
                                                    <div class="d-flex flex-wrap gap-1">
                                                        @foreach (var permiso in grupo.OrderBy(p => p))
                                                        {
                                                            <span class="badge bg-outline-secondary small">
                                                                @permiso.Replace(grupo.Key + "_", "")
                                                            </span>
                                                        }
                                                    </div>
                                                </div>
                                                <span class="badge bg-secondary">@grupo.Count()</span>
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="list-group-item text-muted text-center py-4">
                                        <Icon Name="IconName.ExclamationTriangle" />
                                        <div class="mt-2">Sin permisos asignados</div>
                                        <small>Este rol no tiene permisos configurados en la base de datos</small>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="card-footer bg-light text-muted small">
                            <Icon Name="IconName.Clock" class="me-1" />
                            Configurado en la base de datos
                        </div>
                    </div>
                </div>
            }

            @if (!rolesConPermisos.Any())
            {
                <div class="col-12">
                    <div class="card">
                        <div class="card-body text-center py-5">
                            <Icon Name="IconName.ExclamationCircle" Size="IconSize.x3" class="text-muted mb-3" />
                            <h5 class="text-muted">No se encontraron roles configurados</h5>
                            <p class="text-muted">
                                Verifica la conexión a la base de datos o contacta al administrador del sistema.
                            </p>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Información adicional -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card border-info">
                    <div class="card-header bg-info text-white">
                        <h6 class="mb-0">
                            <Icon Name="IconName.InfoCircle" class="me-2" />
                            Información Técnica
                        </h6>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <div class="col-md-6">
                                <h6>Para modificar permisos:</h6>
                                <ul class="small">
                                    <li>Utiliza herramientas de base de datos (SQL Server Management Studio)</li>
                                    <li>Ejecuta scripts SQL para insertar/actualizar en la tabla <code>RolPermisos</code></li>
                                    <li>Modifica directamente los registros en la tabla <code>Roles</code></li>
                                </ul>
                            </div>
                            <div class="col-md-6">
                                <h6>Tablas principales:</h6>
                                <ul class="small">
                                    <li><code>Roles</code> - Definición de roles</li>
                                    <li><code>RolPermisos</code> - Permisos por rol</li>
                                    <li><code>Recursos</code> - Usuarios con roles asignados</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast de confirmación -->
    @if (mostrarToast)
    {
        <div class="toast align-items-center @(tipoToast == "success" ? "text-bg-success" : "text-bg-danger") border-0 show position-fixed bottom-0 end-0 m-4" 
             role="alert" aria-live="assertive" aria-atomic="true" style="z-index:9999;">
            <div class="d-flex">
                <div class="toast-body">
                    @mensajeToast
                </div>
                <button type="button" class="btn-close btn-close-white me-2 m-auto" @onclick="()=>mostrarToast=false" aria-label="Close"></button>
            </div>
        </div>
    }
</WebGrillaBlazor.Components.AuthorizeView>

@code {
    // Estado de la UI
    private bool mostrarAyuda = false;
    private bool mostrarToast = false;
    private string mensajeToast = string.Empty;
    private string tipoToast = "success";

    // Datos del sistema
    private int totalRoles = 0;
    private int totalPermisos = 0;
    private List<RolConPermisos> rolesConPermisos = new();

    // Clases para los datos
    public class RolConPermisos
    {
        public string NombreRol { get; set; } = string.Empty;
        public List<string> Permisos { get; set; } = new();
        public int TotalPermisos => Permisos.Count;
    }

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        try
        {
            await Task.Delay(100); // Simular carga de datos

            // Cargar roles con permisos (esto vendría de la base de datos)
            CargarRolesConPermisos();

            // Calcular estadísticas
            CalcularEstadisticas();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            MostrarToast($"Error al cargar datos: {ex.Message}", "error");
        }
    }

    private void CargarRolesConPermisos()
    {
        // Esta información normalmente vendría de la base de datos
        // Por ahora simulo los datos basándome en el sistema actual
        rolesConPermisos = new List<RolConPermisos>
        {
            new()
            {
                NombreRol = "Administrador",
                Permisos = new List<string>
                {
                    "RECURSOS_READ", "RECURSOS_WRITE", "RECURSOS_DELETE",
                    "GRILLAS_READ", "GRILLAS_WRITE", "GRILLAS_DELETE",
                    "EVALUACIONES_READ", "EVALUACIONES_WRITE", "EVALUACIONES_DELETE", "EVALUACIONES_ADMIN",
                    "TEMAS_READ", "TEMAS_WRITE", "TEMAS_DELETE",
                    "CLIENTES_READ", "CLIENTES_WRITE", "CLIENTES_DELETE",
                    "TIPOS_DOCUMENTO_READ", "TIPOS_DOCUMENTO_WRITE", "TIPOS_DOCUMENTO_DELETE",
                    "EQUIPOS_READ", "EQUIPOS_WRITE", "EQUIPOS_DELETE",
                    "ROLES_READ", "ROLES_WRITE", "ROLES_DELETE",
                    "PERMISOS_ADMIN", "DASHBOARD_ACCESS", "SISTEMA_ADMIN", "SUPERVISION_READ", "SUPERVISION_WRITE"
                }
            },
            new()
            {
                NombreRol = "Manager",
                Permisos = new List<string>
                {
                    "RECURSOS_READ", "RECURSOS_WRITE",
                    "GRILLAS_READ", "GRILLAS_WRITE",
                    "EVALUACIONES_READ", "EVALUACIONES_WRITE", "EVALUACIONES_ADMIN",
                    "TEMAS_READ", "TEMAS_WRITE",
                    "CLIENTES_READ", "CLIENTES_WRITE",
                    "EQUIPOS_READ", "EQUIPOS_WRITE",
                    "SUPERVISION_READ", "SUPERVISION_WRITE",
                    "DASHBOARD_ACCESS"
                }
            },
            new()
            {
                NombreRol = "Evaluador",
                Permisos = new List<string>
                {
                    "EVALUACIONES_READ", "EVALUACIONES_WRITE",
                    "RECURSOS_READ",
                    "GRILLAS_READ",
                    "TEMAS_READ",
                    "SUPERVISION_READ",
                    "DASHBOARD_ACCESS"
                }
            },
            new()
            {
                NombreRol = "Desarrollador",
                Permisos = new List<string>
                {
                    "RECURSOS_READ",
                    "GRILLAS_READ",
                    "EVALUACIONES_READ",
                    "DASHBOARD_ACCESS"
                }
            },
            new()
            {
                NombreRol = "Supervisor",
                Permisos = new List<string>
                {
                    "RECURSOS_READ",
                    "GRILLAS_READ",
                    "EVALUACIONES_READ", "EVALUACIONES_WRITE",
                    "SUPERVISION_READ", "SUPERVISION_WRITE",
                    "DASHBOARD_ACCESS"
                }
            }
        };
    }

    private void CalcularEstadisticas()
    {
        totalRoles = rolesConPermisos.Count;
        totalPermisos = rolesConPermisos.SelectMany(r => r.Permisos).Distinct().Count();
    }

    private string GetRoleColor(string rol)
    {
        return rol switch
        {
            "Administrador" => "danger",
            "Manager" => "warning",
            "Evaluador" => "info",
            "Desarrollador" => "secondary",
            "Supervisor" => "success",
            _ => "primary"
        };
    }

    private void MostrarToast(string mensaje, string tipo)
    {
        mensajeToast = mensaje;
        tipoToast = tipo;
        mostrarToast = true;
        Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { mostrarToast = false; StateHasChanged(); }));
    }
}