@page "/"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.Services
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Grilla de Conocimiento</PageTitle>

<!-- Componente de autorización que redirige automáticamente si no está autenticado -->
<WebGrillaBlazor.Components.AuthorizeView RedirectToLogin="true">
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="jumbotron bg-primary text-white p-5 rounded mb-4">
                    <h1 class="display-4">🎯 Sistema de Gestión de Grillas de Conocimiento</h1>
                    <p class="lead">Aplicación completa para gestionar evaluaciones de conocimientos por competencias.</p>
                    <hr class="my-4 bg-light">
                    <p>Versión 1.0.0 - Sistema de evaluación por grillas de conocimiento</p>
                    
                    <!-- Mensaje de bienvenida personalizado -->
                    @if (AuthState.IsAuthenticated)
                    {
                        <div class="mt-3">
                            <h5>👋 ¡Bienvenido/a, @AuthState.GetUserDisplayName()!</h5>
                            <p class="mb-0">Rol: <strong>@AuthState.CurrentUser?.NombreRol</strong></p>
                        </div>
                    }
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <Icon Name="IconName.ClipboardCheck" Size="IconSize.x3" class="text-success mb-3" />
                        <h5 class="card-title">Evaluaciones</h5>
                        <p class="card-text">Crear y gestionar evaluaciones de conocimiento para recursos específicos usando grillas personalizadas.</p>
                        @if (AuthState.UserCanAccess("EVALUACIONES"))
                        {
                            <a href="/evaluaciones" class="btn btn-success">Ir a Evaluaciones</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary" disabled>Sin permisos</button>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Grid" Size="IconSize.x3" class="text-primary mb-3" />
                        <h5 class="card-title">Grillas de Conocimiento</h5>
                        <p class="card-text">Configurar y administrar grillas con temas y subtemas para estructurar las evaluaciones.</p>
                        @if (AuthState.UserCanAccess("GRILLAS"))
                        {
                            <a href="/grillas" class="btn btn-primary">Gestionar Grillas</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary" disabled>Sin permisos</button>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <Icon Name="IconName.People" Size="IconSize.x3" class="text-info mb-3" />
                        <h5 class="card-title">Recursos</h5>
                        <p class="card-text">Administrar personas, equipos de desarrollo y sus roles dentro de la organización.</p>
                        @if (AuthState.UserCanAccess("RECURSOS"))
                        {
                            <a href="/recursos" class="btn btn-info">Ver Recursos</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary" disabled>Sin permisos</button>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">
                            <Icon Name="IconName.BookHalf" class="me-2" />
                            Gestión de Contenido
                        </h5>
                        <p class="card-text">Administre temas, subtemas y estructure el conocimiento de manera organizada.</p>
                        <div class="d-flex gap-2">
                            @if (AuthState.UserCanAccess("TEMAS"))
                            {
                                <a href="/temas" class="btn btn-outline-primary btn-sm">Temas</a>
                            }
                            @if (AuthState.UserCanAccess("CLIENTES"))
                            {
                                <a href="/clientes" class="btn btn-outline-primary btn-sm">Clientes</a>
                            }
                            @if (AuthState.UserCanAccess("TIPOS_DOCUMENTO"))
                            {
                                <a href="/tipos" class="btn btn-outline-primary btn-sm">Tipos Documento</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">
                            <Icon Name="IconName.Diagram3" class="me-2" />
                            Organización
                        </h5>
                        <p class="card-text">Configure equipos de desarrollo, roles y la estructura organizacional.</p>
                        <div class="d-flex gap-2">
                            @if (AuthState.UserCanAccess("EQUIPOS"))
                            {
                                <a href="/equipos" class="btn btn-outline-secondary btn-sm">Equipos</a>
                            }
                            @if (AuthState.UserCanAccess("ROLES"))
                            {
                                <a href="/roles" class="btn btn-outline-secondary btn-sm">Roles</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-12">
                <div class="alert alert-info">
                    <h6 class="alert-heading">
                        <Icon Name="IconName.InfoCircle" class="me-2" />
                        ¿Cómo funciona el sistema?
                    </h6>
                    <ol class="mb-0">
                        <li><strong>Configurar:</strong> Crear grillas con temas y subtemas de conocimiento</li>
                        <li><strong>Asignar:</strong> Asignar recursos (personas) a equipos y roles</li>
                        <li><strong>Evaluar:</strong> Crear evaluaciones específicas para un recurso usando una grilla</li>
                        <li><strong>Monitorear:</strong> Seguir el progreso y completitud de las evaluaciones</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
</WebGrillaBlazor.Components.AuthorizeView>

@code {
    protected override async Task OnInitializedAsync()
    {
        // Inicializar el estado de autenticación
        await AuthState.InitializeAsync();
    }
}

