@page "/index"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.Services
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Grilla de Conocimiento</PageTitle>

<!-- Verificar autenticación antes de mostrar contenido -->
@if (isLoading)
{
    <!-- Pantalla de carga mientras se verifica autenticación -->
    <div class="d-flex justify-content-center align-items-center" style="height: 80vh;">
        <div class="text-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <p class="mt-3 text-muted">Verificando estado de autenticación...</p>
        </div>
    </div>
}
else if (AuthState.IsAuthenticated && AuthState.CurrentUser != null)
{
    <!-- Solo mostrar contenido si está autenticado -->
    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="jumbotron bg-primary text-white p-5 rounded mb-4">
                    <h1 class="display-4">🎯 Sistema de Gestión de Grillas de Conocimiento</h1>
                    <p class="lead">Aplicación completa para gestionar evaluaciones de conocimientos por competencias.</p>
                    <hr class="my-4 bg-light">
                    <p>Versión 1.0.0 - Sistema de evaluación por grillas de conocimiento</p>
                    
                    <!-- Mensaje de bienvenida personalizado -->
                    <div class="mt-3">
                        <h5>👋 ¡Bienvenido/a, @AuthState.GetUserDisplayName()!</h5>
                        <p class="mb-0">Rol: <strong>@AuthState.CurrentUser?.NombreRol</strong></p>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <Icon Name="IconName.ClipboardCheck" Size="IconSize.x3" class="text-success mb-3" />
                        <h5 class="card-title">Evaluaciones</h5>
                        <p class="card-text">Crear y gestionar evaluaciones de conocimiento para recursos específicos usando grillas personalizadas.</p>
                        @if (AuthState.UserCanAccess("EVALUACIONES"))
                        {
                            <a href="/evaluaciones" class="btn btn-success">Ir a Evaluaciones</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary" disabled>Sin permisos</button>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <Icon Name="IconName.Grid" Size="IconSize.x3" class="text-primary mb-3" />
                        <h5 class="card-title">Grillas de Conocimiento</h5>
                        <p class="card-text">Configurar y administrar grillas con temas y subtemas para estructurar las evaluaciones.</p>
                        @if (AuthState.UserCanAccess("GRILLAS"))
                        {
                            <a href="/grillas" class="btn btn-primary">Gestionar Grillas</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary" disabled>Sin permisos</button>
                        }
                    </div>
                </div>
            </div>
            
            <div class="col-md-4 mb-4">
                <div class="card h-100 shadow-sm">
                    <div class="card-body text-center">
                        <Icon Name="IconName.People" Size="IconSize.x3" class="text-info mb-3" />
                        <h5 class="card-title">Recursos</h5>
                        <p class="card-text">Administrar personas, equipos de desarrollo y sus roles dentro de la organización.</p>
                        @if (AuthState.UserCanAccess("RECURSOS"))
                        {
                            <a href="/recursos" class="btn btn-info">Ver Recursos</a>
                        }
                        else
                        {
                            <button class="btn btn-outline-secondary" disabled>Sin permisos</button>
                        }
                    </div>
                </div>
            </div>
        </div>
        
        <div class="row mt-4">
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">
                            <Icon Name="IconName.BookHalf" class="me-2" />
                            Gestión de Contenido
                        </h5>
                        <p class="card-text">Administre temas, subtemas y estructure el conocimiento de manera organizada.</p>
                        <div class="d-flex gap-2">
                            @if (AuthState.UserCanAccess("TEMAS"))
                            {
                                <a href="/temas" class="btn btn-outline-primary btn-sm">Temas</a>
                            }
                            @if (AuthState.UserCanAccess("CLIENTES"))
                            {
                                <a href="/clientes" class="btn btn-outline-primary btn-sm">Clientes</a>
                            }
                            @if (AuthState.UserCanAccess("TIPOS_DOCUMENTO"))
                            {
                                <a href="/tipos" class="btn btn-outline-primary btn-sm">Tipos Documento</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="col-md-6 mb-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h5 class="card-title">
                            <Icon Name="IconName.Diagram3" class="me-2" />
                            Organización
                        </h5>
                        <p class="card-text">Configure equipos de desarrollo, roles y la estructura organizacional.</p>
                        <div class="d-flex gap-2">
                            @if (AuthState.UserCanAccess("EQUIPOS"))
                            {
                                <a href="/equipos" class="btn btn-outline-secondary btn-sm">Equipos</a>
                            }
                            @if (AuthState.UserCanAccess("ROLES"))
                            {
                                <a href="/roles" class="btn btn-outline-secondary btn-sm">Roles</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <!-- Nueva sección de Administración solo para administradores -->
        @if (AuthState.UserHasPermission("PERMISOS_ADMIN"))
        {
            <div class="row mt-4">
                <div class="col-12 mb-4">
                    <div class="card border-danger shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title text-danger">
                                <Icon Name="IconName.ShieldLock" class="me-2" />
                                Administración del Sistema
                            </h5>
                            <p class="card-text">Panel de configuración avanzada y gestión de permisos del sistema.</p>
                            <div class="d-flex gap-2">
                                <a href="/permisos" class="btn btn-outline-danger btn-sm">
                                    <Icon Name="IconName.Shield" class="me-1" />
                                    Gestión de Permisos
                                </a>
                                <a href="/admin/permisos-roles" class="btn btn-danger btn-sm">
                                    <Icon Name="IconName.Gear" class="me-1" />
                                    Configurar Permisos y Rutas
                                </a>
                            </div>
                            <div class="mt-2">
                                <small class="text-danger">
                                    <Icon Name="IconName.ExclamationTriangle" class="me-1" />
                                    <strong>Área restringida:</strong> Solo administradores del sistema
                                </small>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        
        <div class="row mt-4">
            <div class="col-12">
                <div class="alert alert-info">
                    <h6 class="alert-heading">
                        <Icon Name="IconName.InfoCircle" class="me-2" />
                        ¿Cómo funciona el sistema?
                    </h6>
                    <ol class="mb-0">
                        <li><strong>Configurar:</strong> Crear grillas con temas y subtemas de conocimiento</li>
                        <li><strong>Asignar:</strong> Asignar recursos (personas) a equipos y roles</li>
                        <li><strong>Evaluar:</strong> Crear evaluaciones específicas para un recurso usando una grilla</li>
                        <li><strong>Monitorear:</strong> Seguir el progreso y completitud de las evaluaciones</li>
                    </ol>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <!-- Si no está autenticado, mostrar mensaje y redirigir -->
    <div class="d-flex justify-content-center align-items-center" style="height: 80vh;">
        <div class="text-center">
            <Icon Name="IconName.ShieldX" Size="IconSize.x5" class="text-warning mb-3" />
            <h3>Acceso Requerido</h3>
            <p class="text-muted">Debe iniciar sesión para acceder al sistema.</p>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="RedirectToLogin">
                    <Icon Name="IconName.BoxArrowInRight" class="me-2" />
                    Ir al Login
                </button>
            </div>
        </div>
    </div>
}

@code {
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("🏠 Index: Inicializando página...");
        
        try
        {
            // NO inicializar AuthState aquí, ya lo hace AppStateInitializer
            // Solo verificar el estado actual después de una pequeña pausa
            await Task.Delay(300);
            
            Console.WriteLine($"🏠 Index: Verificando estado auth...");
            Console.WriteLine($"   - AuthState.IsAuthenticated: {AuthState.IsAuthenticated}");
            Console.WriteLine($"   - AuthState.CurrentUser: {AuthState.CurrentUser?.NombreCompleto ?? "null"}");
            
            // Si no está autenticado, NO forzar redirección aquí
            // Dejar que el AppStateInitializer maneje la navegación
            if (!AuthState.IsAuthenticated)
            {
                Console.WriteLine("🏠 Index: No autenticado, pero NO redirigiendo automáticamente");
                // El AppStateInitializer se encargará de la redirección si es necesario
            }
            else
            {
                Console.WriteLine("🏠 Index: Usuario autenticado, mostrando dashboard");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"❌ Error en Index: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void RedirectToLogin()
    {
        Console.WriteLine("🏠 Index: Redirección manual a login");
        Navigation.NavigateTo("/", forceLoad: true);
    }
}

