        }
    }

    private async Task AplicarFiltros()
    {
        try
        {
            resumenes.Clear();
            evaluacionesSeleccionadas.Clear();
            
            // Obtener evaluaciones base según permisos
            List<EvaluacionDTO> evaluacionesBase = new();
            
            if (soloSupervision && AuthState.CanSupervise())
            {
                evaluacionesBase = await EvaluacionClient.GetEvaluacionesPorSupervisionAsync(AuthState.GetCurrentUserId());
            }
            else if (!soloSupervision && AuthState.CanViewAllEvaluations())
            {
                evaluacionesBase = await EvaluacionClient.GetAllAsync();
            }
            else if (AuthState.CanViewOwnEvaluationsOnly())
            {
                // Solo evaluaciones propias del usuario actual
                evaluacionesBase = await EvaluacionClient.GetMisEvaluacionesAsync(AuthState.GetCurrentUserId());
            }
            else
            {
                // Sin permisos suficientes - no cargar evaluaciones
                evaluacionesBase = new List<EvaluacionDTO>();
                MostrarToast("No tiene permisos para ver evaluaciones", "error");
                StateHasChanged();
                return;
            }

            if (grillaFiltroSeleccionada > 0)
            {
                // Filtrar por grilla específica
                var evaluacionesFiltradas = evaluacionesBase.Where(e => e.IdGrilla == grillaFiltroSeleccionada).ToList();
                
                if (evaluacionesFiltradas.Any())
                {
                    var resumen = CrearResumenDesdeEvaluaciones(evaluacionesFiltradas, grillaFiltroSeleccionada);
                    resumenes.Add(resumen);
                }
            }
            else
            {
                // Agrupar por grilla
                var evaluacionesPorGrilla = evaluacionesBase.GroupBy(e => e.IdGrilla);
                
                foreach (var grupo in evaluacionesPorGrilla)
                {
                    var resumen = CrearResumenDesdeEvaluaciones(grupo.ToList(), grupo.Key);
                    resumenes.Add(resumen);
                }
            }

            // Aplicar filtro por recurso si está seleccionado
            if (recursoFiltroSeleccionado > 0)
            {
                foreach (var resumen in resumenes)
                {
                    resumen.Evaluaciones = resumen.Evaluaciones.Where(e => e.IdRecurso == recursoFiltroSeleccionado).ToList();
                    resumen.TotalEvaluaciones = resumen.Evaluaciones.Count;
                    resumen.EvaluacionesCompletadas = resumen.Evaluaciones.Count(e => e.FechaFin <= DateTime.Now);
                    resumen.EvaluacionesPendientes = resumen.Evaluaciones.Count(e => e.FechaFin > DateTime.Now);
                    resumen.PorcentajeCompletitud = resumen.TotalEvaluaciones > 0 ? 
                        (decimal)resumen.EvaluacionesCompletadas / resumen.TotalEvaluaciones * 100 : 0;
                }
                
                // Remover resúmenes sin evaluaciones
                resumenes = resumenes.Where(r => r.TotalEvaluaciones > 0).ToList();
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al aplicar filtros: {ex.Message}");
            MostrarToast("Error al cargar las evaluaciones", "error");
        }
    }

    private EvaluacionGlobalResumenDTO CrearResumenDesdeEvaluaciones(List<EvaluacionDTO> evaluaciones, int idGrilla)
    {
        var fechaMinima = evaluaciones.Min(e => e.FechaInicio);
        var fechaMaxima = evaluaciones.Max(e => e.FechaFin);
        
        return new EvaluacionGlobalResumenDTO
        {
            IdGrilla = idGrilla,
            FechaInicio = fechaMinima,
            FechaFin = fechaMaxima,
            TotalEvaluaciones = evaluaciones.Count,
            EvaluacionesCompletadas = evaluaciones.Count(e => e.FechaFin <= DateTime.Now),
            EvaluacionesPendientes = evaluaciones.Count(e => e.FechaFin > DateTime.Now),
            PorcentajeCompletitud = evaluaciones.Count > 0 ? 
                (decimal)evaluaciones.Count(e => e.FechaFin <= DateTime.Now) / evaluaciones.Count * 100 : 0,
            Evaluaciones = evaluaciones,
            NombreGrilla = grillas.FirstOrDefault(g => g.IdGrilla == idGrilla)?.Nombre
        };
    }

    private async Task MostrarSoloSupervision()
    {
        soloSupervision = true;
        await DeterminarRecursosDisponibles();
        await AplicarFiltros();
