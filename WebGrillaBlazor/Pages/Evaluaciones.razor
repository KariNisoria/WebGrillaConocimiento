@page "/evaluaciones"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.ApiClient
@inject ApiClientEvaluacion EvaluacionClient
@inject ApiClientGeneric<RecursoDTO> RecursoClient
@inject ApiClientGeneric<GrillaDTO> GrillaClient
@inject NavigationManager Navigation

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col">
            <h3>Gestión de Evaluaciones</h3>
            <small class="text-muted">Gestiona y monitorea todas las evaluaciones del sistema</small>
        </div>
        <div class="col-auto">
            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="RefrescarDatos">
                <Icon Name="IconName.ArrowClockwise" /> Refrescar
            </Button>
        </div>
    </div>

    <!-- Filtros -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h6 class="mb-0">
                        <Icon Name="IconName.FunnelFill" /> Filtros
                    </h6>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-3">
                            <label for="filtroGrilla" class="form-label">Grilla</label>
                            <select class="form-select" id="filtroGrilla" @bind="grillaFiltroSeleccionada">
                                <option value="0">Todas las grillas</option>
                                @foreach (var grilla in grillas)
                                {
                                    <option value="@grilla.IdGrilla">@grilla.Nombre</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label for="filtroRecurso" class="form-label">Recurso</label>
                            <select class="form-select" id="filtroRecurso" @bind="recursoFiltroSeleccionado">
                                <option value="0">Todos los recursos</option>
                                @foreach (var recurso in recursos)
                                {
                                    <option value="@recurso.IdRecurso">@recurso.Nombre @recurso.Apellido</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-2">
                            <label for="fechaDesde" class="form-label">Desde</label>
                            <input type="date" class="form-control" id="fechaDesde" @bind="fechaDesde" />
                        </div>
                        <div class="col-md-2">
                            <label for="fechaHasta" class="form-label">Hasta</label>
                            <input type="date" class="form-control" id="fechaHasta" @bind="fechaHasta" />
                        </div>
                        <div class="col-md-2">
                            <label class="form-label">&nbsp;</label>
                            <div>
                                <Button Color="ButtonColor.Primary" Size="ButtonSize.Small" @onclick="AplicarFiltros">
                                    <Icon Name="IconName.Search" /> Buscar
                                </Button>
                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="LimpiarFiltros" class="ms-1">
                                    <Icon Name="IconName.XCircle" /> Limpiar
                                </Button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sección para iniciar nueva evaluación -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <Icon Name="IconName.Plus" /> Iniciar Nueva Evaluación
                    </h5>
                </div>
                <div class="card-body">
                    <!-- Tabs para Individual vs Global -->
                    <ul class="nav nav-tabs mb-3" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(tipoEvaluacion == "individual" ? "active" : "")" 
                                    @onclick='() => CambiarTipoEvaluacion("individual")' 
                                    type="button">
                                <Icon Name="IconName.Person" /> Evaluación Individual
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="nav-link @(tipoEvaluacion == "global" ? "active" : "")" 
                                    @onclick='() => CambiarTipoEvaluacion("global")' 
                                    type="button">
                                <Icon Name="IconName.People" /> Evaluación Global
                            </button>
                        </li>
                    </ul>

                    <!-- Contenido del tab Individual -->
                    @if (tipoEvaluacion == "individual")
                    {
                        <div class="row">
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label for="recursoEvaluacion" class="form-label">Recurso</label>
                                    <select class="form-select" id="recursoEvaluacion" @bind="recursoSeleccionadoId">
                                        <option value="0">Seleccionar recurso...</option>
                                        @foreach (var recurso in recursos)
                                        {
                                            <option value="@recurso.IdRecurso">@recurso.Nombre @recurso.Apellido</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label for="grillaEvaluacion" class="form-label">Grilla</label>
                                    <select class="form-select" id="grillaEvaluacion" @bind="grillaSeleccionadaId">
                                        <option value="0">Seleccionar grilla...</option>
                                        @foreach (var grilla in grillas)
                                        {
                                            <option value="@grilla.IdGrilla">@grilla.Nombre</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label for="descripcionEvaluacion" class="form-label">Descripción</label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="descripcionEvaluacion" 
                                           @bind="nuevaDescripcionEvaluacion"
                                           placeholder="Ej: Evaluación Q1 2024" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <div class="mb-3">
                                    <label for="fechaFin" class="form-label">Fecha Fin</label>
                                    <input type="datetime-local" 
                                           class="form-control" 
                                           id="fechaFin" 
                                           @bind="fechaFinEvaluacion"
                                           min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <Button Color="ButtonColor.Success" 
                                        @onclick="CrearNuevaEvaluacion"
                                        Disabled="@(string.IsNullOrWhiteSpace(nuevaDescripcionEvaluacion) || fechaFinEvaluacion <= DateTime.Now || grillaSeleccionadaId <= 0 || recursoSeleccionadoId <= 0)">
                                    <Icon Name="IconName.PlayFill" /> Crear Evaluación Individual
                                </Button>
                            </div>
                        </div>
                    }

                    <!-- Contenido del tab Global -->
                    @if (tipoEvaluacion == "global")
                    {
                        <div class="alert alert-info">
                            <Icon Name="IconName.InfoCircle" class="me-2" />
                            <strong>Evaluación Global:</strong> Se creará automáticamente una evaluación para todos los recursos en la base de datos.
                        </div>
                        <div class="row">
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="grillaEvaluacionGlobal" class="form-label">Grilla para Evaluación Global</label>
                                    <select class="form-select" id="grillaEvaluacionGlobal" @bind="grillaGlobalSeleccionadaId">
                                        <option value="0">Seleccionar grilla...</option>
                                        @foreach (var grilla in grillas)
                                        {
                                            <option value="@grilla.IdGrilla">@grilla.Nombre</option>
                                        }
                                    </select>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="descripcionEvaluacionGlobal" class="form-label">Descripción Base</label>
                                    <input type="text" 
                                           class="form-control" 
                                           id="descripcionEvaluacionGlobal" 
                                           @bind="descripcionEvaluacionGlobal"
                                           placeholder="Ej: Evaluación Global Q1 2024" />
                                    <small class="text-muted">Se agregará el nombre del recurso automáticamente</small>
                                </div>
                            </div>
                            <div class="col-md-4">
                                <div class="mb-3">
                                    <label for="fechaFinGlobal" class="form-label">Fecha Fin</label>
                                    <input type="datetime-local" 
                                           class="form-control" 
                                           id="fechaFinGlobal" 
                                           @bind="fechaFinEvaluacionGlobal"
                                           min="@DateTime.Now.ToString("yyyy-MM-ddTHH:mm")" />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-12">
                                <Button Color="ButtonColor.Warning" 
                                        @onclick="CrearEvaluacionGlobal"
                                        Disabled="@(string.IsNullOrWhiteSpace(descripcionEvaluacionGlobal) || fechaFinEvaluacionGlobal <= DateTime.Now || grillaGlobalSeleccionadaId <= 0 || creandoEvaluacionGlobal)">
                                    @if (creandoEvaluacionGlobal)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    }
                                    else
                                    {
                                        <Icon Name="IconName.Globe" />
                                    }
                                    Crear Evaluación Global para Todos los Recursos
                                </Button>
                                @if (totalRecursos > 0)
                                {
                                    <small class="text-muted d-block mt-1">
                                        Se crearán <strong>@totalRecursos evaluaciones</strong> (una por recurso)
                                    </small>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Resumen de evaluaciones globales -->
    @if (resumenes.Any())
    {
        <div class="row mb-4">
            <div class="col-12">
                <h5>
                    <Icon Name="IconName.BarChart" /> Todas las Evaluaciones
                </h5>
            </div>
        </div>

        @foreach (var resumen in resumenes.OrderByDescending(r => r.FechaInicio))
        {
            <div class="row mb-3">
                <div class="col-12">
                    <div class="card border-@(resumen.PorcentajeCompletitud >= 100 ? "success" : resumen.PorcentajeCompletitud >= 50 ? "warning" : "danger")">
                        <div class="card-header bg-@(resumen.PorcentajeCompletitud >= 100 ? "success" : resumen.PorcentajeCompletitud >= 50 ? "warning" : "danger") text-white">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-1">
                                        <Icon Name="IconName.Calendar" /> @resumen.FechaInicio.ToString("dd/MM/yyyy") - @resumen.FechaFin.ToString("dd/MM/yyyy")
                                    </h6>
                                    <small>@(resumen.NombreGrilla ?? "Grilla no especificada")</small>
                                </div>
                                <div class="text-end">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="text-center">
                                            <div class="fw-bold fs-4">@resumen.PorcentajeCompletitud.ToString("F1")%</div>
                                            <small>Completitud</small>
                                        </div>
                                        <Button Color="ButtonColor.Light" Size="ButtonSize.Small" @onclick="() => ToggleDetalleResumen(resumen.IdGrilla, resumen.FechaInicio)">
                                            <Icon Name="IconName.ChevronDown" /> Detalles
                                        </Button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="row">
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="display-6 text-info">@resumen.TotalEvaluaciones</div>
                                        <small class="text-muted">Total Evaluaciones</small>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="display-6 text-success">@resumen.EvaluacionesCompletadas</div>
                                        <small class="text-muted">Completadas</small>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-center">
                                        <div class="display-6 text-warning">@resumen.EvaluacionesPendientes</div>
                                        <small class="text-muted">Pendientes</small>
                                    </div>
                                </div>
                                <div class="col-md-3">
                                    <div class="progress" style="height: 20px;">
                                        <div class="progress-bar bg-@(resumen.PorcentajeCompletitud >= 100 ? "success" : resumen.PorcentajeCompletitud >= 50 ? "warning" : "danger")" 
                                             style="width: @resumen.PorcentajeCompletitud%">
                                        </div>
                                    </div>
                                    <small class="text-muted">Progreso General</small>
                                </div>
                            </div>
                            
                            @if (resumenExpandido == $"{resumen.IdGrilla}_{resumen.FechaInicio:yyyyMMdd}")
                            {
                                <div class="mt-3 pt-3 border-top">
                                    <div class="d-flex justify-content-between align-items-center mb-3">
                                        <h6>Evaluaciones Individuales</h6>
                                        @if (evaluacionesSeleccionadas.Any())
                                        {
                                            <div>
                                                <Button Color="ButtonColor.Warning" Size="ButtonSize.Small" @onclick="FinalizarEvaluacionesSeleccionadas" class="me-2">
                                                    <Icon Name="IconName.StopFill" /> Finalizar Seleccionadas (@evaluacionesSeleccionadas.Count)
                                                </Button>
                                                <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="LimpiarSeleccion">
                                                    <Icon Name="IconName.XCircle" /> Limpiar Selección
                                                </Button>
                                            </div>
                                        }
                                    </div>
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover">
                                            <thead>
                                                <tr>
                                                    <th style="width: 40px;">
                                                        <input type="checkbox" 
                                                               class="form-check-input" 
                                                               @onchange="@(e => ToggleTodasLasEvaluaciones(resumen.Evaluaciones, (bool)e.Value!))" 
                                                               checked="@(resumen.Evaluaciones.All(ev => evaluacionesSeleccionadas.Contains(ev.IdEvaluacion)))" />
                                                    </th>
                                                    <th>ID</th>
                                                    <th>Recurso</th>
                                                    <th>Descripción</th>
                                                    <th>Estado</th>
                                                    <th>Fecha Inicio</th>
                                                    <th>Fecha Fin</th>
                                                    <th>Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var evaluacion in resumen.Evaluaciones.OrderBy(e => e.NombreRecurso))
                                                {
                                                    <tr>
                                                        <td>
                                                            <input type="checkbox" 
                                                                   class="form-check-input" 
                                                                   @onchange="@(e => ToggleSeleccionEvaluacion(evaluacion.IdEvaluacion, (bool)e.Value!))" 
                                                                   checked="@evaluacionesSeleccionadas.Contains(evaluacion.IdEvaluacion)" />
                                                        </td>
                                                        <td>@evaluacion.IdEvaluacion</td>
                                                        <td>@evaluacion.NombreRecurso</td>
                                                        <td>@evaluacion.Descripcion</td>
                                                        <td>
                                                            @if (evaluacion.FechaFin <= DateTime.Now)
                                                            {
                                                                <span class="badge bg-secondary">
                                                                    <Icon Name="IconName.Clock" /> Expirada
                                                                </span>
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-info">
                                                                    <Icon Name="IconName.PlayFill" /> Activa
                                                                </span>
                                                            }
                                                        </td>
                                                        <td>@evaluacion.FechaInicio.ToString("dd/MM/yyyy HH:mm")</td>
                                                        <td>@evaluacion.FechaFin.ToString("dd/MM/yyyy HH:mm")</td>
                                                        <td>
                                                            <div class="btn-group" role="group">
                                                                <Button Color="ButtonColor.Primary" 
                                                                        Size="ButtonSize.ExtraSmall" 
                                                                        @onclick="() => AccederAEvaluacion(evaluacion.IdEvaluacion, evaluacion.IdRecurso)">
                                                                    <Icon Name="IconName.PlayFill" /> Evaluar
                                                                </Button>
                                                                <Button Color="ButtonColor.Warning" 
                                                                        Size="ButtonSize.ExtraSmall" 
                                                                        @onclick="() => FinalizarEvaluacionIndividual(evaluacion.IdEvaluacion)"
                                                                        Disabled="@(evaluacion.FechaFin <= DateTime.Now)">
                                                                    <Icon Name="IconName.StopFill" /> Finalizar
                                                                </Button>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        @if (cargandoDatos)
                        {
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p class="mt-3">Cargando evaluaciones...</p>
                        }
                        else
                        {
                            <Icon Name="IconName.ExclamationTriangle" Size="IconSize.x2" />
                            <p class="mt-2">No se encontraron evaluaciones</p>
                            <small class="text-muted">
                                Las evaluaciones aparecerán aquí cuando se crean desde el panel de arriba.
                            </small>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Toast de confirmación -->
@if (mostrarToast)
{
    <div class="toast align-items-center @(tipoToast == "success" ? "text-bg-success" : "text-bg-danger") border-0 show position-fixed bottom-0 end-0 m-4" role="alert" aria-live="assertive" aria-atomic="true" style="z-index:9999;">
        <div class="d-flex">
            <div class="toast-body">
                @mensajeToast
            </div>
            <button type="button" class="btn-close @(tipoToast == "success" ? "btn-close-white" : "btn-close-white") me-2 m-auto" @onclick="()=>mostrarToast=false" aria-label="Close"></button>
        </div>
    </div>
}

@code {
    private List<RecursoDTO> recursos = new();
    private List<GrillaDTO> grillas = new();
    private List<EvaluacionDTO> evaluacionesHistorial = new();
    private List<EvaluacionGlobalResumenDTO> resumenes = new();
    private EvaluacionDTO? evaluacionActiva;
    
    // Filtros
    private int grillaFiltroSeleccionada = 0;
    private int recursoFiltroSeleccionado = 0;
    private DateTime fechaDesde = DateTime.Now.AddDays(-30);
    private DateTime fechaHasta = DateTime.Now.AddDays(30);
    private string resumenExpandido = string.Empty;
    
    // Variables para evaluación individual
    private string nuevaDescripcionEvaluacion = string.Empty;
    private DateTime fechaFinEvaluacion = DateTime.Now.AddDays(30);
    private int grillaSeleccionadaId = 0;
    private int recursoSeleccionadoId = 0;
    
    // Variables para evaluación global
    private string tipoEvaluacion = "individual"; // "individual" o "global"
    private string descripcionEvaluacionGlobal = string.Empty;
    private DateTime fechaFinEvaluacionGlobal = DateTime.Now.AddDays(30);
    private int grillaGlobalSeleccionadaId = 0;
    private bool creandoEvaluacionGlobal = false;
    
    // Selección múltiple de evaluaciones
    private HashSet<int> evaluacionesSeleccionadas = new();
    
    // Estados
    private bool cargandoDatos = true;
    private bool mostrarToast = false;
    private string mensajeToast = string.Empty;
    private string tipoToast = "success";

    // Propiedades calculadas
    private int totalRecursos => recursos.Count;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        cargandoDatos = true;
        try
        {
            var tareasAsync = new List<Task>
            {
                CargarRecursos(),
                CargarGrillas(),
                CargarEvaluacionActiva()
            };
            
            await Task.WhenAll(tareasAsync);
            await AplicarFiltros();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos: {ex.Message}");
        }
        finally
        {
            cargandoDatos = false;
        }
    }

    private async Task CargarRecursos()
    {
        try
        {
            recursos = await RecursoClient.GetAllAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar recursos: {ex.Message}");
            recursos = new List<RecursoDTO>();
        }
    }

    private async Task CargarGrillas()
    {
        try
        {
            grillas = await GrillaClient.GetAllAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar grillas: {ex.Message}");
            grillas = new List<GrillaDTO>();
        }
    }

    private async Task CargarEvaluacionActiva()
    {
        try
        {
            evaluacionActiva = await EvaluacionClient.GetEvaluacionActivaAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar evaluación activa: {ex.Message}");
            evaluacionActiva = null;
        }
    }

    private async Task AplicarFiltros()
    {
        try
        {
            resumenes.Clear();
            evaluacionesSeleccionadas.Clear();
            
            if (grillaFiltroSeleccionada > 0)
            {
                // Obtener resumen para una grilla específica
                var resumen = await EvaluacionClient.GetResumenEvaluacionGlobalAsync(grillaFiltroSeleccionada, fechaDesde, fechaHasta);
                if (resumen != null && resumen.TotalEvaluaciones > 0)
                {
                    resumen.NombreGrilla = grillas.FirstOrDefault(g => g.IdGrilla == grillaFiltroSeleccionada)?.Nombre;
                    
                    // Aplicar filtro por recurso si está seleccionado
                    if (recursoFiltroSeleccionado > 0)
                    {
                        resumen.Evaluaciones = resumen.Evaluaciones.Where(e => e.IdRecurso == recursoFiltroSeleccionado).ToList();
                        resumen.TotalEvaluaciones = resumen.Evaluaciones.Count;
                        resumen.EvaluacionesCompletadas = resumen.Evaluaciones.Count(e => e.FechaFin <= DateTime.Now);
                        resumen.EvaluacionesPendientes = resumen.Evaluaciones.Count(e => e.FechaFin > DateTime.Now);
                        resumen.PorcentajeCompletitud = resumen.TotalEvaluaciones > 0 ? 
                            (decimal)resumen.EvaluacionesCompletadas / resumen.TotalEvaluaciones * 100 : 0;
                    }
                    
                    if (resumen.TotalEvaluaciones > 0)
                        resumenes.Add(resumen);
                }
            }
            else
            {
                // Obtener resúmenes para todas las grillas
                foreach (var grilla in grillas)
                {
                    var resumen = await EvaluacionClient.GetResumenEvaluacionGlobalAsync(grilla.IdGrilla, fechaDesde, fechaHasta);
                    if (resumen != null && resumen.TotalEvaluaciones > 0)
                    {
                        resumen.NombreGrilla = grilla.Nombre;
                        
                        // Aplicar filtro por recurso si está seleccionado
                        if (recursoFiltroSeleccionado > 0)
                        {
                            resumen.Evaluaciones = resumen.Evaluaciones.Where(e => e.IdRecurso == recursoFiltroSeleccionado).ToList();
                            resumen.TotalEvaluaciones = resumen.Evaluaciones.Count;
                            resumen.EvaluacionesCompletadas = resumen.Evaluaciones.Count(e => e.FechaFin <= DateTime.Now);
                            resumen.EvaluacionesPendientes = resumen.Evaluaciones.Count(e => e.FechaFin > DateTime.Now);
                            resumen.PorcentajeCompletitud = resumen.TotalEvaluaciones > 0 ? 
                                (decimal)resumen.EvaluacionesCompletadas / resumen.TotalEvaluaciones * 100 : 0;
                        }
                        
                        if (resumen.TotalEvaluaciones > 0)
                            resumenes.Add(resumen);
                    }
                }
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al aplicar filtros: {ex.Message}");
            MostrarToast("Error al cargar las evaluaciones", "error");
        }
    }

    private async Task LimpiarFiltros()
    {
        grillaFiltroSeleccionada = 0;
        recursoFiltroSeleccionado = 0;
        fechaDesde = DateTime.Now.AddDays(-30);
        fechaHasta = DateTime.Now.AddDays(30);
        await AplicarFiltros();
    }

    private void ToggleDetalleResumen(int idGrilla, DateTime fechaInicio)
    {
        var key = $"{idGrilla}_{fechaInicio:yyyyMMdd}";
        resumenExpandido = resumenExpandido == key ? string.Empty : key;
        evaluacionesSeleccionadas.Clear(); // Limpiar selección al cambiar de resumen
        StateHasChanged();
    }

    private void ToggleSeleccionEvaluacion(int idEvaluacion, bool seleccionado)
    {
        if (seleccionado)
            evaluacionesSeleccionadas.Add(idEvaluacion);
        else
            evaluacionesSeleccionadas.Remove(idEvaluacion);
            
        StateHasChanged();
    }

    private void ToggleTodasLasEvaluaciones(List<EvaluacionDTO> evaluaciones, bool seleccionarTodas)
    {
        if (seleccionarTodas)
        {
            foreach (var evaluacion in evaluaciones)
            {
                evaluacionesSeleccionadas.Add(evaluacion.IdEvaluacion);
            }
        }
        else
        {
            foreach (var evaluacion in evaluaciones)
            {
                evaluacionesSeleccionadas.Remove(evaluacion.IdEvaluacion);
            }
        }
        StateHasChanged();
    }

    private void LimpiarSeleccion()
    {
        evaluacionesSeleccionadas.Clear();
        StateHasChanged();
    }

    private async Task FinalizarEvaluacionesSeleccionadas()
    {
        if (!evaluacionesSeleccionadas.Any())
        {
            MostrarToast("No hay evaluaciones seleccionadas", "error");
            return;
        }

        try
        {
            var evaluacionesFinalizadas = 0;
            foreach (var idEvaluacion in evaluacionesSeleccionadas)
            {
                var evaluacion = await EvaluacionClient.GetByIdAsync(idEvaluacion);
                if (evaluacion != null)
                {
                    evaluacion.FechaFin = DateTime.Now;
                    await EvaluacionClient.UpdateAsync(idEvaluacion, evaluacion);
                    evaluacionesFinalizadas++;
                }
            }

            evaluacionesSeleccionadas.Clear();
            await AplicarFiltros();
            MostrarToast($"Se finalizaron {evaluacionesFinalizadas} evaluaciones correctamente", "success");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al finalizar evaluaciones: {ex.Message}");
            MostrarToast("Error al finalizar las evaluaciones seleccionadas", "error");
        }
    }

    private async Task FinalizarEvaluacionIndividual(int idEvaluacion)
    {
        try
        {
            var evaluacion = await EvaluacionClient.GetByIdAsync(idEvaluacion);
            if (evaluacion != null)
            {
                evaluacion.FechaFin = DateTime.Now;
                await EvaluacionClient.UpdateAsync(idEvaluacion, evaluacion);
                await AplicarFiltros();
                MostrarToast("Evaluación finalizada correctamente", "success");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al finalizar evaluación: {ex.Message}");
            MostrarToast("Error al finalizar la evaluación", "error");
        }
    }

    private void AccederAEvaluacion(int idEvaluacion, int idRecurso)
    {
        Navigation.NavigateTo($"/evaluacion/{idEvaluacion}/recurso/{idRecurso}");
    }

    private async Task CrearNuevaEvaluacion()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(nuevaDescripcionEvaluacion))
            {
                MostrarToast("La descripción es obligatoria", "error");
                return;
            }

            if (fechaFinEvaluacion <= DateTime.Now)
            {
                MostrarToast("La fecha fin debe ser mayor a la fecha actual", "error");
                return;
            }

            var nuevaEvaluacion = new EvaluacionDTO
            {
                Descripcion = nuevaDescripcionEvaluacion.Trim(),
                FechaInicio = DateTime.Now,
                FechaFin = fechaFinEvaluacion,
                IdRecurso = recursoSeleccionadoId,
                IdGrilla = grillaSeleccionadaId
            };

            await EvaluacionClient.CreateAsync(nuevaEvaluacion);
            
            // Limpiar formulario
            nuevaDescripcionEvaluacion = string.Empty;
            fechaFinEvaluacion = DateTime.Now.AddDays(30);
            grillaSeleccionadaId = 0;
            recursoSeleccionadoId = 0;

            await AplicarFiltros();
            MostrarToast("Evaluación creada correctamente", "success");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al crear evaluación: {ex.Message}");
            MostrarToast("Error al crear la evaluación", "error");
        }
    }

    private async Task CrearEvaluacionGlobal()
    {
        creandoEvaluacionGlobal = true;
        try
        {
            if (string.IsNullOrWhiteSpace(descripcionEvaluacionGlobal))
            {
                MostrarToast("La descripción es obligatoria", "error");
                return;
            }

            if (fechaFinEvaluacionGlobal <= DateTime.Now)
            {
                MostrarToast("La fecha fin debe ser mayor a la fecha actual", "error");
                return;
            }

            if (grillaGlobalSeleccionadaId <= 0)
            {
                MostrarToast("Debe seleccionar una grilla", "error");
                return;
            }

            var evaluacionesCreadas = await EvaluacionClient.CrearEvaluacionGlobalAsync(
                grillaGlobalSeleccionadaId,
                descripcionEvaluacionGlobal.Trim(),
                fechaFinEvaluacionGlobal);

            if (evaluacionesCreadas.Any())
            {
                // Limpiar formulario
                descripcionEvaluacionGlobal = string.Empty;
                fechaFinEvaluacionGlobal = DateTime.Now.AddDays(30);
                grillaGlobalSeleccionadaId = 0;

                await AplicarFiltros();
                MostrarToast($"Evaluación global creada correctamente: {evaluacionesCreadas.Count} evaluaciones generadas", "success");
                
                // Cambiar a la sección del panel global
                tipoEvaluacion = "individual";
            }
            else
            {
                MostrarToast("No se crearon evaluaciones. Verifique que existan recursos en la base de datos.", "warning");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al crear evaluación global: {ex.Message}");
            MostrarToast("Error al crear la evaluación global", "error");
        }
        finally
        {
            creandoEvaluacionGlobal = false;
        }
    }

    private async Task RefrescarDatos()
    {
        await CargarDatos();
    }

    private void MostrarToast(string mensaje, string tipo)
    {
        mensajeToast = mensaje;
        tipoToast = tipo;
        mostrarToast = true;
        Task.Delay(3000).ContinueWith(_ => InvokeAsync(() => { mostrarToast = false; StateHasChanged(); }));
    }

    private void CambiarTipoEvaluacion(string tipo)
    {
        tipoEvaluacion = tipo;
        
        // Limpiar formularios y seleccionar primer recurso y grilla por defecto
        nuevaDescripcionEvaluacion = string.Empty;
        fechaFinEvaluacion = DateTime.Now.AddDays(30);
        grillaSeleccionadaId = 0;
        recursoSeleccionadoId = 0;

        descripcionEvaluacionGlobal = string.Empty;
        fechaFinEvaluacionGlobal = DateTime.Now.AddDays(30);
        grillaGlobalSeleccionadaId = 0;
    }
}