@page "/clientes"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.ApiClient
@using WebGrillaBlazor.Services
@inject ApiClientGeneric<ClienteDTO> ClienteClient
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Gestión de Clientes</PageTitle>

<WebGrillaBlazor.Components.AuthorizeView RedirectToLogin="true">
    @if (!AuthState.UserCanAccess("CLIENTES"))
    {
        <div class="alert alert-danger">
            <h4 class="alert-heading">Acceso Denegado</h4>
            <p>No tienes permisos para acceder a la gestión de clientes.</p>
            <hr>
            <p class="mb-0">
                <strong>Permisos requeridos:</strong> CLIENTES_READ<br>
                <strong>Tu rol actual:</strong> @AuthState.CurrentUser?.NombreRol<br>
                Contacta con un administrador si necesitas acceso a esta funcionalidad.
            </p>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="NavigateToIndex">
                    <Icon Name="IconName.ArrowLeft" class="me-1" />
                    Volver al Dashboard
                </button>
            </div>
        </div>
        return;
    }

    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col">
                <h3>
                    <Icon Name="IconName.Building" class="me-2 text-primary" />
                    Gestión de Clientes
                </h3>
                <p class="text-muted">Administrar clientes y organizaciones del sistema</p>
            </div>
            <div class="col-auto">
                @if (AuthState.UserHasPermission("CLIENTES_WRITE"))
                {
                    <Button Color="ButtonColor.Success" Size="ButtonSize.Small" @onclick="AddCliente">
                        <Icon Name="IconName.Plus" class="me-1" />
                        Agregar Cliente
                    </Button>
                }
                else
                {
                    <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" disabled title="Sin permisos de escritura">
                        <Icon Name="IconName.Lock" class="me-1" />
                        Sin permisos
                    </Button>
                }
            </div>
        </div>

        <div class="card">
            <div class="card-body">
                <Grid @ref="gridCliente"
                      TItem="ClienteDTO"
                      Class="table table-hover table-bordered table-striped"
                      DataProvider="GetAllClientes"
                      AllowPaging="true"
                      PageSize="10"
                      AllowSorting="true"
                      AllowRowClick="true"
                      OnRowDoubleClick="OnClienteDobleClick"
                      SelectionMode="GridSelectionMode.Single"
                      Responsive="true">

                    <GridColumns>
                        <GridColumn TItem="ClienteDTO" HeaderText="ID" PropertyName="IdCliente" SortKeySelector="item => item.IdCliente">
                            @context.IdCliente
                        </GridColumn>

                        <GridColumn TItem="ClienteDTO" HeaderText="Nombre del Cliente" PropertyName="Descripcion" SortKeySelector="item => item.Nombre">
                            <strong>@context.Nombre</strong>
                        </GridColumn>
                        
                        @if (AuthState.UserHasPermission("CLIENTES_WRITE"))
                        {
                            <GridColumn TItem="ClienteDTO" HeaderText="Acciones">
                                <Button Color="ButtonColor.Primary" Size="ButtonSize.ExtraSmall" @onclick="() => EditarCliente(context)">
                                    <Icon Name="IconName.Pencil" />
                                </Button>
                            </GridColumn>
                        }
                    </GridColumns>
                </Grid>
            </div>
        </div>

        <!-- Ficha Edicion Cliente -->
        <Modal @ref="_EdicionCliente" UseStaticBackdrop="true" CloseOnEscape="false" Size="ModalSize.Large" />
        
        <!-- Información adicional para usuarios sin permisos de escritura -->
        @if (!AuthState.UserHasPermission("CLIENTES_WRITE"))
        {
            <div class="alert alert-info mt-3">
                <Icon Name="IconName.InfoCircle" class="me-2" />
                <strong>Modo solo lectura:</strong> Puedes consultar los clientes pero no realizar modificaciones.
            </div>
        }
    </div>
</WebGrillaBlazor.Components.AuthorizeView>

@code {
    private List<ClienteDTO> clientes;
    private int currentIdCliente = 0;
    private Modal _EdicionCliente = default!;
    private Grid<ClienteDTO> gridCliente = default!;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("Clientes: Inicializando página...");
        Console.WriteLine($"   - Usuario: {AuthState.CurrentUser?.NombreCompleto}");
        Console.WriteLine($"   - Puede acceder: {AuthState.UserCanAccess("CLIENTES")}");
        Console.WriteLine($"   - Permisos escritura: {AuthState.UserHasPermission("CLIENTES_WRITE")}");
        
        clientes = await ClienteClient.GetAllAsync();
        await base.OnInitializedAsync();
    }

    private void NavigateToIndex()
    {
        Navigation.NavigateTo("/index");
    }

    private async Task<GridDataProviderResult<ClienteDTO>> GetAllClientes(GridDataProviderRequest<ClienteDTO> request)
    {
        Console.WriteLine("GetAllClientes");

        if (clientes is null) // pull clientes only one time for client-side filtering, sorting, and paging
            clientes = await ClienteClient.GetAllAsync(); // call a service or an API to pull the clientes

        return await Task.FromResult(request.ApplyTo(clientes));
    }

    private async Task AddCliente()
    {
        if (!AuthState.UserHasPermission("CLIENTES_WRITE"))
        {
            Console.WriteLine("Sin permisos para crear cliente");
            return;
        }

        var lista = clientes.ToList();
        var nuevo = CreateCliente();
        lista.Add(nuevo);
        clientes = lista;
        await gridCliente.RefreshDataAsync();
    }

    private ClienteDTO CreateCliente()
    {
        // Usar DefaultIfEmpty() para manejar colecciones vacías de forma segura
        var numero = (clientes?.Any() == true) ? clientes.Max(x => x.IdCliente) + 1 : 1;

        var nuevo = new ClienteDTO();

        nuevo.IdCliente = 0;
        nuevo.Nombre = $"Nuevo Cliente {numero}";

        return nuevo;
    }

    private async Task EditarCliente(ClienteDTO cliente)
    {
        if (!AuthState.UserHasPermission("CLIENTES_WRITE"))
        {
            Console.WriteLine("Sin permisos para editar cliente");
            return;
        }
        
        var param = new Dictionary<string, object>();
        param.Add("OnClickCallback", EventCallback.Factory.Create<MouseEventArgs>(this, OnCloseModalEdicionCliente));
        param.Add("cliente", cliente);
        await _EdicionCliente.ShowAsync<FichaCliente>(title: "Edición Cliente", parameters: param);
    }

    private async Task OnClienteDobleClick(GridRowEventArgs<ClienteDTO> args)
    {
        if (!AuthState.UserHasPermission("CLIENTES_WRITE"))
        {
            Console.WriteLine("Sin permisos para editar cliente - doble click ignorado");
            return;
        }
        
        Console.WriteLine("Evento OnClienteDobleClick");
        var param = new Dictionary<string, object>();
        param.Add("OnClickCallback", EventCallback.Factory.Create<MouseEventArgs>(this, OnCloseModalEdicionCliente));
        param.Add("cliente", args.Item);
        await _EdicionCliente.ShowAsync<FichaCliente>(title: "Edición Cliente", parameters: param);
    }

    private async Task OnCloseModalEdicionCliente()
    {
        Console.WriteLine("OnCloseModalEdicionCliente()");
        await _EdicionCliente.HideAsync(); // Ocultar el formulario de Edicion
        await RefreshGrid(); // Refrescar la grilla
    }

    private async Task RefreshGrid()
    {
        clientes = null; // Limpiar la caché local de clientes
        await gridCliente.RefreshDataAsync();
        StateHasChanged(); // Forzar la actualización de la grilla
    }

    private async Task OnRowClick(GridRowEventArgs<ClienteDTO> args)
    {
        Console.WriteLine($"OnRowClick Cliente current: {currentIdCliente} nuevo: {args.Item.IdCliente} ");
        currentIdCliente = args.Item.IdCliente;
    }
}