@page "/tipos"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.ApiClient
@using WebGrillaBlazor.Services
@inject ApiClientGeneric<TipoDocumentoDTO> ApiClient
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Gestión de Tipos de Documento</PageTitle>

<WebGrillaBlazor.Components.AuthorizeView RedirectToLogin="true">
    @if (!AuthState.UserCanAccess("TIPOS_DOCUMENTO"))
    {
        <div class="alert alert-danger">
            <h4 class="alert-heading">Acceso Denegado</h4>
            <p>No tienes permisos para acceder a la gestión de tipos de documento.</p>
            <hr>
            <p class="mb-0">
                <strong>Permisos requeridos:</strong> TIPOS_DOCUMENTO_READ<br>
                <strong>Tu rol actual:</strong> @AuthState.CurrentUser?.NombreRol<br>
                Contacta con un administrador si necesitas acceso a esta funcionalidad.
            </p>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/index"))">
                    <Icon Name="IconName.ArrowLeft" class="me-1" />
                    Volver al Dashboard
                </button>
            </div>
        </div>
        return;
    }

    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col">
                <h3>
                    <Icon Name="IconName.CardText" class="me-2 text-primary" />
                    Gestión de Tipos de Documento
                </h3>
                <p class="text-muted">Administrar tipos de documentos de identificación del sistema</p>
            </div>
            <div class="col-auto">
                @if (AuthState.UserHasPermission("TIPOS_DOCUMENTO_WRITE"))
                {
                    <Button Color="ButtonColor.Success" Size="ButtonSize.Small" @onclick="AddTipoDocumento">
                        <Icon Name="IconName.Plus" class="me-1" />
                        Agregar Tipo Documento
                    </Button>
                }
                else
                {
                    <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" disabled title="Sin permisos de escritura">
                        <Icon Name="IconName.Lock" class="me-1" />
                        Sin permisos
                    </Button>
                }
            </div>
        </div>

        <!-- Grilla de tipos de documentos -->
        <div class="card">
            <div class="card-body">
                <Grid @ref="gridTipo"
                      TItem="TipoDocumentoDTO"
                      Class="table table-hover table-bordered table-striped"
                      DataProvider="GetAllTipoDocumento"
                      AllowPaging="true"
                      PageSize="10"
                      AllowSorting="true"
                      AllowRowClick="true"
                      OnRowDoubleClick="OnTipoDocumentoDobleClick"
                      SelectionMode="GridSelectionMode.Single"
                      Responsive="true">

                    <GridColumns>
                        <GridColumn TItem="TipoDocumentoDTO" HeaderText="ID" PropertyName="IdTipoDocumento" SortKeySelector="item => item.IdTipoDocumento">
                            @context.IdTipoDocumento
                        </GridColumn>

                        <GridColumn TItem="TipoDocumentoDTO" HeaderText="Nombre" PropertyName="Nombre" SortKeySelector="item => item.Nombre">
                            <strong>@context.Nombre</strong>
                        </GridColumn>

                        <GridColumn TItem="TipoDocumentoDTO" HeaderText="Abreviación" PropertyName="Abreviacion" SortKeySelector="item => item.Abreviacion">
                            <span class="badge bg-info">@context.Abreviacion</span>
                        </GridColumn>
                        
                        @if (AuthState.UserHasPermission("TIPOS_DOCUMENTO_WRITE"))
                        {
                            <GridColumn TItem="TipoDocumentoDTO" HeaderText="Acciones">
                                <Button Color="ButtonColor.Primary" Size="ButtonSize.ExtraSmall" @onclick="() => EditarTipoDocumento(context)">
                                    <Icon Name="IconName.Pencil" />
                                </Button>
                            </GridColumn>
                        }
                    </GridColumns>
                </Grid>
            </div>
        </div>

        <!-- Ficha Edicion Tipo Documento -->
        <Modal @ref="_EdicionTipoDocumento" UseStaticBackdrop="true" CloseOnEscape="false" Size="ModalSize.Large" />
        
        <!-- Información adicional para usuarios sin permisos de escritura -->
        @if (!AuthState.UserHasPermission("TIPOS_DOCUMENTO_WRITE"))
        {
            <div class="alert alert-info mt-3">
                <Icon Name="IconName.InfoCircle" class="me-2" />
                <strong>Modo solo lectura:</strong> Puedes consultar los tipos de documento pero no realizar modificaciones.
            </div>
        }
    </div>
</WebGrillaBlazor.Components.AuthorizeView>

@code {
    private IEnumerable<TipoDocumentoDTO> tipos = default!;
    private int currentIdTipoDocumento = 0;
    private Modal _EdicionTipoDocumento = default!;
    private Grid<TipoDocumentoDTO> gridTipo = default!;

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("Tipos Documento: Inicializando página...");
        Console.WriteLine($"   - Usuario: {AuthState.CurrentUser?.NombreCompleto}");
        Console.WriteLine($"   - Puede acceder: {AuthState.UserCanAccess("TIPOS_DOCUMENTO")}");
        Console.WriteLine($"   - Permisos escritura: {AuthState.UserHasPermission("TIPOS_DOCUMENTO_WRITE")}");

        await base.OnInitializedAsync();
    }

    private async Task<GridDataProviderResult<TipoDocumentoDTO>> GetAllTipoDocumento(GridDataProviderRequest<TipoDocumentoDTO> request)
    {
        Console.WriteLine("GetAllTipoDocumento");

        if (tipos is null)
            tipos = await ApiClient.GetAllAsync();

        return await Task.FromResult(request.ApplyTo(tipos));
    }

    private async Task AddTipoDocumento()
    {
        if (!AuthState.UserHasPermission("TIPOS_DOCUMENTO_WRITE"))
        {
            Console.WriteLine("Sin permisos para crear tipo documento");
            return;
        }

        var lista = tipos.ToList();
        var nuevo = CreateTipoDocumento();
        lista.Add(nuevo);
        tipos = lista;
        await gridTipo.RefreshDataAsync();
    }

    private TipoDocumentoDTO CreateTipoDocumento()
    {
        // Usar verificación para manejar colecciones vacías de forma segura
        var numero = (tipos?.Any() == true) ? tipos.Max(x => x.IdTipoDocumento) + 1 : 1;

        var nuevo = new TipoDocumentoDTO();

        nuevo.IdTipoDocumento = 0;
        nuevo.Nombre = $"Nuevo Tipo Documento {numero}";
        nuevo.Abreviacion = $"TD{numero}";

        return nuevo;
    }

    private async Task EditarTipoDocumento(TipoDocumentoDTO tipoDocumento)
    {
        if (!AuthState.UserHasPermission("TIPOS_DOCUMENTO_WRITE"))
        {
            Console.WriteLine("Sin permisos para editar tipo documento");
            return;
        }
        
        var param = new Dictionary<string, object>();
        param.Add("OnClickCallback", EventCallback.Factory.Create<MouseEventArgs>(this, OnCloseModalEdicionTipoDocumento));
        param.Add("tipoDocumento", tipoDocumento);
        await _EdicionTipoDocumento.ShowAsync<FichaTipoDocumento>(title: "Edición Tipo Documento", parameters: param);
    }

    private async Task OnTipoDocumentoDobleClick(GridRowEventArgs<TipoDocumentoDTO> args)
    {
        if (!AuthState.UserHasPermission("TIPOS_DOCUMENTO_WRITE"))
        {
            Console.WriteLine("Sin permisos para editar tipo documento - doble click ignorado");
            return;
        }
        
        Console.WriteLine("Evento OnTipoDocumentoDobleClick");
        var param = new Dictionary<string, object>();
        param.Add("OnClickCallback", EventCallback.Factory.Create<MouseEventArgs>(this, OnCloseModalEdicionTipoDocumento));
        param.Add("tipoDocumento", args.Item);
        await _EdicionTipoDocumento.ShowAsync<FichaTipoDocumento>(title: "Edición Tipo Documento", parameters: param);
    }

    private async Task OnCloseModalEdicionTipoDocumento()
    {
        Console.WriteLine("OnCloseModalEdicionTipoDocumento()");
        await _EdicionTipoDocumento.HideAsync();
        await RefreshGrid();
    }

    private async Task RefreshGrid()
    {
        tipos = null;
        await gridTipo.RefreshDataAsync();
        StateHasChanged();
    }

    private async Task OnRowClick(GridRowEventArgs<TipoDocumentoDTO> args)
    {
        Console.WriteLine($"OnRowClick TipoDocumento current: {currentIdTipoDocumento} nuevo: {args.Item.IdTipoDocumento} ");
        currentIdTipoDocumento = args.Item.IdTipoDocumento;
    }
}
