    private async Task FinalizarEvaluacion()
    {
        finalizandoEvaluacion = true;
        try
        {
            if (evaluacion == null)
            {
                MostrarToast("Error: No se pudo cargar la evaluación", "error");
                return;
            }

            // 1. Identificar todos los subtemas de la grilla
            var todosLosSubtemas = grillaSubtemas.Select(s => s.IdSubtema).ToList();

            // 2. Identificar subtemas que ya tienen conocimientos guardados
            var subtemasConConocimiento = conocimientos
                .Where(c => c.IdConocimientoRecurso > 0)
                .Select(c => c.IdSubtema)
                .ToList();

            // 3. Identificar subtemas pendientes (sin registro en BD)
            var subtemasPendientes = todosLosSubtemas
                .Except(subtemasConConocimiento)
                .ToList();

            // 4. Crear registros con valores 0,0 para los subtemas pendientes
            var conocimientosPendientes = subtemasPendientes.Select(idSubtema => new ConocimientoRecursoDTO
            {
                IdConocimientoRecurso = 0,
                IdSubtema = idSubtema,
                IdRecurso = IdRecurso,
                IdEvaluacion = IdEvaluacion,
                IdGrilla = evaluacion.IdGrilla,
                ValorFuncional = 0,
                ValorTecnico = 0,
                ValorFuncionalVerif = null,
                ValorTecnicoVerif = null
            }).ToList();

            if (conocimientosPendientes.Any())
            {
                Console.WriteLine($"Guardando {conocimientosPendientes.Count} conocimientos pendientes con valores 0,0");
                var conocimientosGuardados = await ConocimientoClient.GuardarMultiplesAsync(conocimientosPendientes);

                // Agregar los conocimientos guardados a la lista local
                conocimientos.AddRange(conocimientosGuardados);

            }

            // 5. Actualizar la fecha de fin de la evaluación al momento actual
            evaluacion.FechaFin = DateTime.Now;
            var evaluacionActualizada = await EvaluacionClient.UpdateAsync(IdEvaluacion, evaluacion);

            if (evaluacionActualizada != null)
            {
                evaluacion = evaluacionActualizada;
                await OcultarModalFinalizarEvaluacion();
                MostrarToast($"Evaluación finalizada correctamente. Se guardaron {conocimientosPendientes.Count} registros pendientes.", "success");
                StateHasChanged();

                // Redirigir después de 3 segundos
                await Task.Delay(3000);
                Navigation.NavigateTo("/evaluaciones");
            }
            else
            {
                MostrarToast("Error al finalizar la evaluación", "error");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al finalizar evaluación: {ex.Message}");
            MostrarToast("Error al finalizar la evaluación: " + ex.Message, "error");
        }
        finally
        {
            finalizandoEvaluacion = false;
        }
    }

