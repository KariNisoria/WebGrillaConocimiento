    private async Task GuardarConocimiento(int idSubtema)
    {
        guardandoConocimiento = true;
        try
        {
            var conocimiento = conocimientos.FirstOrDefault(c => c.IdSubtema == idSubtema);
            if (conocimiento != null)
            {
                // Validar que no sea un registro con 0,0 que ya existe en BD
                if (conocimiento.IdConocimientoRecurso > 0 &&
                    conocimiento.ValorFuncional == 0 &&
                    conocimiento.ValorTecnico == 0)
                {
                    MostrarToast("No se pueden guardar registros con valores 0,0", "warning");
                    return;
                }

                var conocimientoGuardado = await ConocimientoClient.CrearOActualizarAsync(conocimiento);

                var index = conocimientos.FindIndex(c => c.IdSubtema == idSubtema);
                if (index >= 0)
                {
                    conocimientos[index] = conocimientoGuardado;
                }

                MostrarToast("Conocimiento guardado correctamente", "success");
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar conocimiento: {ex.Message}");
            MostrarToast("Error al guardar el conocimiento", "error");
        }
        finally
        {
            guardandoConocimiento = false;
        }
    }

    private async Task GuardarTodoElTema(int idGrillaTema)
    {
        guardandoTema = true;
        try
        {
            var tema = temasBinarizados.FirstOrDefault(t => t.IdGrillaTema == idGrillaTema);
            if (tema == null) return;

            var subtemasDelTema = tema.Subtemas.Select(s => s.IdSubtema).ToList();

            // Filtrar conocimientos que no sean 0,0 o que sean nuevos (IdConocimientoRecurso == 0)
            var conocimientosParaGuardar = conocimientos
                .Where(c => subtemasDelTema.Contains(c.IdSubtema) &&
                           (c.IdConocimientoRecurso == 0 || c.ValorFuncional > 0 || c.ValorTecnico > 0))
                .ToList();

            if (conocimientosParaGuardar.Any())
            {
                var conocimientosGuardados = await ConocimientoClient.GuardarMultiplesAsync(conocimientosParaGuardar);

                foreach (var conocimientoGuardado in conocimientosGuardados)
                {
                    var index = conocimientos.FindIndex(c =>
                        c.IdSubtema == conocimientoGuardado.IdSubtema &&
                        c.IdRecurso == conocimientoGuardado.IdRecurso &&
                        c.IdEvaluacion == conocimientoGuardado.IdEvaluacion);

                    if (index >= 0)
                    {
                        conocimientos[index] = conocimientoGuardado;
                    }
                }

                MostrarToast($"Tema '{tema.Nombre}' guardado correctamente ({conocimientosGuardados.Count} subtemas)", "success");
            }
            else
            {
                MostrarToast($"No hay cambios para guardar en el tema '{tema.Nombre}'", "warning");
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar tema: {ex.Message}");
            MostrarToast("Error al guardar el tema", "error");
        }
        finally
        {
            guardandoTema = false;
        }
    }

    private async Task GuardarTodoElProgreso()
    {
        guardandoTodo = true;
        try
        {
            // Filtrar conocimientos que no sean 0,0 o que sean nuevos (IdConocimientoRecurso == 0)
            var conocimientosParaGuardar = conocimientos
                .Where(c => c.IdConocimientoRecurso == 0 || c.ValorFuncional > 0 || c.ValorTecnico > 0)
                .ToList();

            if (conocimientosParaGuardar.Any())
            {
                var conocimientosGuardados = await ConocimientoClient.GuardarMultiplesAsync(conocimientosParaGuardar);

                foreach (var conocimientoGuardado in conocimientosGuardados)
                {
                    var index = conocimientos.FindIndex(c =>
                        c.IdSubtema == conocimientoGuardado.IdSubtema &&
                        c.IdRecurso == conocimientoGuardado.IdRecurso &&
                        c.IdEvaluacion == conocimientoGuardado.IdEvaluacion);

                    if (index >= 0)
                    {
                        conocimientos[index] = conocimientoGuardado;
                    }
                }

                MostrarToast($"Todo el progreso ha sido guardado correctamente ({conocimientosGuardados.Count} conocimientos)", "success");
            }
            else
            {
                MostrarToast("No hay cambios para guardar", "warning");
            }

