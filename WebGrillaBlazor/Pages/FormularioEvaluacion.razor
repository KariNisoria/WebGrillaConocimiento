        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al guardar todo el progreso: {ex.Message}");
            MostrarToast("Error al guardar el progreso", "error");
        }
        finally
        {
            guardandoTodo = false;
        }
    }

