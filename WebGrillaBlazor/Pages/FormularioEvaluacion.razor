@page "/evaluacion/{IdEvaluacion:int}/recurso/{IdRecurso:int}"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.ApiClient
@using WebGrillaBlazor.Services
@inject ApiClientEvaluacion EvaluacionClient
@inject ApiClientConocimiento ConocimientoClient
@inject ApiClientGeneric<RecursoDTO> RecursoClient
@inject ApiClientGeneric<GrillaTemaDTO> GrillaTemaClient
@inject ApiClientGeneric<GrillaSubtemaDTO> GrillaSubtemaClient
@inject ApiClientRecursoSupervisor RecursoSupervisorClient
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="container-fluid">
    <!-- Header -->
    <div class="row mb-3">
        <div class="col">
            <h3>Evaluación de Conocimientos</h3>
            @if (recurso != null && evaluacion != null)
            {
                <div class="d-flex align-items-center gap-3">
                    <span class="badge bg-primary fs-6">@recurso.Nombre @(recurso.Apellidos ?? recurso.Apellido)</span>
                    <span class="text-muted">|</span>
                    <span class="badge bg-info fs-6">@evaluacion.Descripcion</span>
                    <span class="text-muted">|</span>
                    <small class="text-muted">
                        Progreso: <strong>@progresoTotal.ToString("F1")%</strong>
                    </small>
                    @if (esRecursoDueńo)
                    {
                        <span class="badge bg-success">
                            <Icon Name="IconName.PersonFill" /> Tu Evaluación
                        </span>
                    }
                    @if (esSupervisor)
                    {
                        <span class="badge bg-warning text-dark">
                            <Icon Name="IconName.ShieldCheck" /> Supervisor
                        </span>
                    }
                    @if (evaluacionFinalizada)
                    {
                        <span class="badge bg-danger">
                            <Icon Name="IconName.StopCircleFill" /> Finalizada
                        </span>
                    }
                </div>
            }
        </div>
        <div class="col-auto">
            <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" @onclick="VolverAEvaluaciones">
                <Icon Name="IconName.ArrowLeft" /> Volver a Evaluaciones
            </Button>
        </div>
    </div>

    <!-- Barra de progreso general - FIJA -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card progress-general-fixed">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h6 class="mb-0">Progreso General</h6>
                        <small class="text-muted">@subtemasCargados de @totalSubtemas subtemas evaluados</small>
                    </div>
                    <div class="progress" style="height: 25px;">
                        <div class="progress-bar @GetProgressBarClass()"
                             role="progressbar"
                             style="width: @progresoTotal%"
                             aria-valuenow="@progresoTotal"
                             aria-valuemin="0"
                             aria-valuemax="100">
                            @progresoTotal.ToString("F1")%
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sistema de TABS para Temas -->
    @if (temasBinarizados.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="evaluation-tabs">
                    <!-- Navigation Tabs -->
                    <ul class="nav nav-tabs" role="tablist">
                        @for (int i = 0; i < temasBinarizados.Count; i++)
                        {
                            var tema = temasBinarizados.OrderBy(t => t.Orden).ElementAt(i);
                            var tabId = $"tema-tab-{tema.IdGrillaTema}";
                            var isActive = i == temaActivo;

                            <li class="nav-item" role="presentation">
                                <button class="nav-link @(isActive ? "active" : "")"
                                        id="@($"{tabId}-tab")"
                                        data-bs-toggle="tab"
                                        data-bs-target="@($"#{tabId}")"
                                        type="button"
                                        role="tab"
                                        aria-controls="@tabId"
                                        aria-selected="@(isActive ? "true" : "false")"
                                        @onclick="@(() => CambiarTemaActivo(i))">
                                    <span>@tema.Nombre</span>
                                    <span class="tab-ponderacion-badge">@tema.Ponderacion.ToString("F1")%</span>
                                    <span class="tab-progress-indicator @GetProgressIndicatorClass(tema.ProgresoCompletitud)"
                                          title="Progreso: @tema.ProgresoCompletitud.ToString("F1")%"></span>
                                </button>
                            </li>
                        }
                    </ul>

                    <!-- Tab Content -->
                    <div class="tab-content">
                        @for (int i = 0; i < temasBinarizados.Count; i++)
                        {
                            var tema = temasBinarizados.OrderBy(t => t.Orden).ElementAt(i);
                            var tabId = $"tema-tab-{tema.IdGrillaTema}";
                            var isActive = i == temaActivo;

                            <div class="tab-pane fade @(isActive ? "show active" : "")"
                                 id="@tabId"
                                 role="tabpanel"
                                 aria-labelledby="@($"{tabId}-tab")"
                                 tabindex="0">

                                <!-- Header del tema en el tab -->
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <div class="d-flex align-items-center gap-3">
                                        <h4 class="mb-0">@tema.Nombre</h4>
                                        <span class="badge bg-secondary fs-6">@tema.Ponderacion.ToString("F1")%</span>
                                        @if (tema.ProgresoCompletitud >= 100)
                                        {
                                            <span class="badge bg-success">
                                                <Icon Name="IconName.CheckCircle" /> Completo
                                            </span>
                                        }
                                        else if (tema.ProgresoCompletitud > 0)
                                        {
                                            <span class="badge bg-warning">
                                                <Icon Name="IconName.Clock" /> En Progreso
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">
                                                <Icon Name="IconName.Dash" /> Pendiente
                                            </span>
                                        }
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <small class="text-muted">
                                            Progreso: <strong>@tema.ProgresoCompletitud.ToString("F1")%</strong>
                                        </small>
                                        <div class="progress progress-completitud" style="width: 150px;">
                                            <div class="progress-bar @(tema.ProgresoCompletitud >= 100 ? "bg-success" : "bg-warning")"
                                                 style="width: @Math.Min(tema.ProgresoCompletitud, 100)%">
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Contenido del tema -->
                                @if (!tema.Subtemas.Any())
                                {
                                    <div class="no-subtemas">
                                        <Icon Name="IconName.InfoCircle" Size="IconSize.x3" />
                                        <h5>No hay subtemas para evaluar</h5>
                                        <p class="text-muted">Este tema no tiene subtemas configurados para la evaluación.</p>
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table table-sm table-hover">
                                            <thead>
                                                <tr>
                                                    <th style="width: 40%;">Subtema</th>
                                                    <th style="width: 15%;" class="text-center">
                                                        Valor Funcional (0-5)
                                                        @if (esRecursoDueńo)
                                                        {
                                                            <br />
                                                            <small class="text-success">Editable</small>
                                                        }
                                                    </th>
                                                    <th style="width: 15%;" class="text-center">
                                                        Valor Técnico (0-5)
                                                        @if (esRecursoDueńo)
                                                        {
                                                            <br />
                                                            <small class="text-success">Editable</small>
                                                        }
                                                    </th>
                                                    <th style="width: 15%;" class="text-center">
                                                        Valor Funcional Verificado (0-5)
                                                        @if (esSupervisor)
                                                        {
                                                            <br />
                                                            <small class="text-warning">Supervisor</small>
                                                        }
                                                    </th>
                                                    <th style="width: 15%;" class="text-center">
                                                        Valor Técnico Verificado (0-5)
                                                        @if (esSupervisor)
                                                        {
                                                            <br />
                                                            <small class="text-warning">Supervisor</small>
                                                        }
                                                    </th>
                                                    <th style="width: 10%;" class="text-center">Estado</th>
                                                    <th style="width: 5%;" class="text-center">Acciones</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var subtema in tema.Subtemas.OrderBy(s => s.Orden))
                                                {
                                                    var conocimiento = conocimientos.FirstOrDefault(c => c.IdSubtema == subtema.IdSubtema);
                                                    var puedeEditarVerificacion = esSupervisor && conocimiento != null &&
                                                    (conocimiento.ValorFuncional > 0 || conocimiento.ValorTecnico > 0);
                                                    var esRegistroVacio = conocimiento != null && conocimiento.ValorFuncional == 0 && conocimiento.ValorTecnico == 0;

                                                    <tr class="@(conocimiento != null ? "table-light" : "")">
                                                        <td>
                                                            <div>
                                                                <strong>@subtema.Nombre</strong>
                                                                @if (!string.IsNullOrEmpty(subtema.Descripcion))
                                                                {
                                                                    <small class="text-muted d-block">@subtema.Descripcion</small>
                                                                }
                                                            </div>
                                                        </td>

                                                        <!-- Valor Funcional - Solo recurso dueńo -->
                                                        <td class="text-center">
                                                            <input type="number"
                                                                   class="form-control form-control-sm text-center @(esRecursoDueńo ? "border-success" : "")"
                                                                   min="0"
                                                                   max="5"
                                                                   step="1"
                                                                   value="@(conocimiento?.ValorFuncional ?? 0)"
                                                                   @onchange="@(e => ActualizarValorFuncional(subtema.IdSubtema, e))"
                                                                   disabled="@(!esRecursoDueńo)"
                                                                   title="@(esRecursoDueńo ? "Puedes editar este valor" : "Solo el recurso puede editar este valor")" />
                                                        </td>

                                                        <!-- Valor Técnico - Solo recurso dueńo -->
                                                        <td class="text-center">
                                                            <input type="number"
                                                                   class="form-control form-control-sm text-center @(esRecursoDueńo ? "border-success" : "")"
                                                                   min="0"
                                                                   max="5"
                                                                   step="1"
                                                                   value="@(conocimiento?.ValorTecnico ?? 0)"
                                                                   @onchange="@(e => ActualizarValorTecnico(subtema.IdSubtema, e))"
                                                                   disabled="@(!esRecursoDueńo)"
                                                                   title="@(esRecursoDueńo ? "Puedes editar este valor" : "Solo el recurso puede editar este valor")" />
                                                        </td>

                                                        <!-- Valor Funcional Verificado - Solo supervisor y si valores > 0 -->
                                                        <td class="text-center">
                                                            <input type="number"
                                                                   class="form-control form-control-sm text-center @(puedeEditarVerificacion ? "border-warning" : "")"
                                                                   min="0"
                                                                   max="5"
                                                                   step="1"
                                                                   value="@(conocimiento?.ValorFuncionalVerif ?? 0)"
                                                                   @onchange="@(e => ActualizarValorFuncionalVerif(subtema.IdSubtema, e))"
                                                                   disabled="@(!puedeEditarVerificacion)"
                                                                   title="@(puedeEditarVerificacion ? "Puedes verificar este valor como supervisor" : !esSupervisor ? "Solo supervisores pueden verificar" : "Primero deben cargarse los valores funcional y técnico")" />

                                                        </td>

                                                        <!-- Valor Técnico Verificado - Solo supervisor y si valores > 0 -->
                                                        <td class="text-center">
                                                            <input type="number"
                                                                   class="form-control form-control-sm text-center @(puedeEditarVerificacion ? "border-warning" : "")"
                                                                   min="0"
                                                                   max="5"
                                                                   step="1"
                                                                   value="@(conocimiento?.ValorTecnicoVerif ?? 0)"
                                                                   @onchange="@(e => ActualizarValorTecnicoVerif(subtema.IdSubtema, e))"
                                                                   disabled="@(!puedeEditarVerificacion)"
                                                                   title="@(puedeEditarVerificacion ? "Puedes verificar este valor como supervisor" : !esSupervisor ? "Solo supervisores pueden verificar" : "Primero deben cargarse los valores funcional y técnico")" />

                                                        </td>

                                                        <!-- Estado -->
                                                        <td class="text-center">
                                                            @if (conocimiento != null && (conocimiento.ValorFuncional > 0 || conocimiento.ValorTecnico > 0))
                                                            {
                                                                @if (conocimiento.ValorFuncionalVerif.HasValue || conocimiento.ValorTecnicoVerif.HasValue)
                                                                {
                                                                    <span class="badge bg-success">
                                                                        <Icon Name="IconName.CheckCircleFill" /> Verificado
                                                                    </span>
                                                                }
                                                                else
                                                                {
                                                                    <span class="badge bg-warning text-dark">
                                                                        <Icon Name="IconName.Clock" /> Pendiente Verificación
                                                                    </span>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <span class="badge bg-secondary">
                                                                    <Icon Name="IconName.Dash" /> Pendiente
                                                                </span>
                                                            }
                                                        </td>

                                                        <!-- Acciones -->
                                                        <td class="text-center">
                                                            <Button Color="ButtonColor.Primary"
                                                                    Size="ButtonSize.ExtraSmall"
                                                                    Class="btn-save-row"
                                                                    @onclick="@(() => GuardarConocimiento(subtema.IdSubtema))"
                                                                    Disabled="@(guardandoConocimiento || (!esRecursoDueńo && !esSupervisor) || (esRegistroVacio && conocimiento.IdConocimientoRecurso > 0))"
                                                                    Title="@(esRegistroVacio && conocimiento.IdConocimientoRecurso > 0 ? "No se pueden guardar registros con valores 0,0" : "Guardar conocimiento")">
                                                                @if (guardandoConocimiento)
                                                                {
                                                                    <Icon Name="IconName.HourglassSplit" />
                                                                }
                                                                else
                                                                {
                                                                    <Icon Name="IconName.FloppyFill" />
                                                                }
                                                            </Button>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }

                                <!-- Botones de acción específicos del tema actual -->
                                @if (tema.Subtemas.Any() && (esRecursoDueńo || esSupervisor))
                                {
                                    <div class="mt-4 p-3 bg-light rounded">
                                        <div class="d-flex justify-content-between align-items-center">
                                            <div>
                                                <strong>Tema: @tema.Nombre</strong>
                                                <small class="text-muted d-block">
                                                    @tema.Subtemas.Count subtemas •
                                                    @tema.Subtemas.Count(s => conocimientos.Any(c => c.IdSubtema == s.IdSubtema && (c.ValorFuncional > 0 || c.ValorTecnico > 0))) evaluados
                                                </small>
                                            </div>
                                            <div class="btn-group" role="group">
                                                <Button Color="ButtonColor.Success"
                                                        Size="ButtonSize.Small"
                                                        @onclick="@(() => GuardarTodoElTema(tema.IdGrillaTema))"
                                                        Disabled="@guardandoTema">
                                                    @if (guardandoTema)
                                                    {
                                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                                    }
                                                    else
                                                    {
                                                        <Icon Name="IconName.CloudCheck" />
                                                    }
                                                    Guardar Tema
                                                </Button>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-body text-center py-5">
                        @if (cargandoDatos)
                        {
                            <div class="spinner-border text-primary" role="status">
                                <span class="visually-hidden">Cargando...</span>
                            </div>
                            <p class="mt-3">Cargando datos de evaluación...</p>
                        }
                        else
                        {
                            <Icon Name="IconName.ExclamationTriangle" Size="IconSize.x2" />
                            <p class="mt-2">No hay temas disponibles para evaluar</p>
                            <small class="text-muted">
                                Verifica que la evaluación tenga una grilla asignada con temas configurados.<br />
                                <strong>Debug Info:</strong><br />
                                - Evaluación ID: @IdEvaluacion<br />
                                - Recurso ID: @IdRecurso<br />
                                - Grilla ID: @(evaluacion?.IdGrilla.ToString() ?? "No asignada")<br />
                                - Temas encontrados: @grillaTemas.Count<br />
                                - Subtemas encontrados: @grillaSubtemas.Count
                            </small>
                        }
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- Botones de acción globales -->
    @if (temasBinarizados.Any() && (esRecursoDueńo || esSupervisor))
    {
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1">Acciones Globales de Evaluación</h6>
                                <small class="text-muted">
                                    Progreso actual: @progresoTotal.ToString("F1")% completado •
                                    @temasBinarizados.Count temas • @totalSubtemas subtemas totales
                                    @if (esRecursoDueńo)
                                    {
                                        <br />
                                        <span class="text-success">Puedes editar valores funcional y técnico</span>
                                    }
                                    @if (esSupervisor)
                                    {
                                        <br />
                                        <span class="text-warning">Puedes verificar valores evaluados</span>
                                    }
                                    @if (evaluacionFinalizada)
                                    {
                                        <br />
                                        <span class="text-danger">
                                            <Icon Name="IconName.ExclamationTriangle" /> Esta evaluación ha sido finalizada
                                        </span>
                                    }
                                </small>
                            </div>
                            <div class="btn-group" role="group">
                                <Button Color="ButtonColor.Success"
                                        @onclick="GuardarTodoElProgreso"
                                        Disabled="@(guardandoTodo || evaluacionFinalizada)">
                                    @if (guardandoTodo)
                                    {
                                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                    }
                                    else
                                    {
                                        <Icon Name="IconName.CloudCheck" />
                                    }
                                    Guardar Todo el Progreso
                                </Button>
                                @if (esRecursoDueńo && !evaluacionFinalizada)
                                {
                                    <Button Color="ButtonColor.Danger"
                                            @onclick="MostrarModalFinalizarEvaluacion"
                                            Disabled="@finalizandoEvaluacion"
                                            Class="ms-2">
                                        @if (finalizandoEvaluacion)
                                        {
                                            <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                                        }
                                        else
                                        {
                                            <Icon Name="IconName.StopCircleFill" />
                                        }
                                        Finalizar Evaluación
                                    </Button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal de confirmación para finalizar evaluación -->
<div class="modal fade" id="modalFinalizarEvaluacion" tabindex="-1" aria-labelledby="modalFinalizarEvaluacionLabel" aria-hidden="true" data-bs-backdrop="static">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="modalFinalizarEvaluacionLabel">
                    <Icon Name="IconName.ExclamationTriangleFill" /> Finalizar Evaluación
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="alert alert-warning">
                    <Icon Name="IconName.InfoCircleFill" class="me-2" />
                    <strong>Atención:</strong> Esta acción no se puede deshacer.
                </div>
                <p class="mb-3">
                    <strong>Se cerrará su evaluación en curso. żEstá seguro?</strong>
                </p>
                <p class="text-muted mb-0">
                    Al finalizar la evaluación:
                </p>
                <ul class="text-muted">
                    <li>La fecha de fin se actualizará al momento actual</li>
                    <li>Se guardarán automáticamente todos los registros pendientes con valores 0,0</li>
                    <li>No podrá realizar más cambios en esta evaluación</li>
                </ul>
            </div>
            <div class="modal-footer">
                <Button Color="ButtonColor.Secondary" data-bs-dismiss="modal">
                    <Icon Name="IconName.XCircle" /> Cancelar
                </Button>
                <Button Color="ButtonColor.Danger" @onclick="FinalizarEvaluacion" Disabled="@finalizandoEvaluacion">
                    @if (finalizandoEvaluacion)
                    {
                        <span class="spinner-border spinner-border-sm me-1" role="status"></span>
                        <text>Finalizando...</text>
                    }
                    else
                    {
                        <Icon Name="IconName.CheckCircleFill" />
                        @(" Sí, Finalizar Evaluación")
                    }
                </Button>
            </div>
        </div>
    </div>
</div>

<!-- Toast de confirmación -->
@if (mostrarToast)
{
    <div class="toast align-items-center @(tipoToast == "success" ? "text-bg-success" : tipoToast == "warning" ? "text-bg-warning" : "text-bg-danger") border-0 show position-fixed bottom-0 end-0 m-4" role="alert" aria-live="assertive" aria-atomic="true" style="z-index:9999;">
        <div class="d-flex">
            <div class="toast-body">
                @mensajeToast
            </div>
            <button type="button" class="btn-close @(tipoToast == "success" ? "btn-close-white" : "btn-close-white") me-2 m-auto" @onclick="() => mostrarToast = false" aria-label="Close"></button>
        </div>
    </div>
}

@code {
    [Parameter] public int IdEvaluacion { get; set; }
    [Parameter] public int IdRecurso { get; set; }

    private EvaluacionDTO? evaluacion;
    private RecursoDTO? recurso;
    private List<GrillaTemaDTO> grillaTemas = new();
    private List<GrillaSubtemaDTO> grillaSubtemas = new();
    private List<ConocimientoRecursoDTO> conocimientos = new();
    private List<TemaConSubtemasEvaluacion> temasBinarizados = new();

    // Variables de permisos y roles
    private bool esRecursoDueńo = false;
    private bool esSupervisor = false;

    private bool cargandoDatos = true;
    private bool guardandoConocimiento = false;
    private bool guardandoTodo = false;
    private bool guardandoTema = false;
    private bool finalizandoEvaluacion = false;
    private bool mostrarToast = false;
    private string mensajeToast = string.Empty;
    private string tipoToast = "success";

    // Control de tabs
    private int temaActivo = 0;

    // Estado de evaluación
    private bool evaluacionFinalizada => evaluacion != null && evaluacion.FechaFin <= DateTime.Now;

    // Clase auxiliar para organizar temas con sus subtemas
    public class TemaConSubtemasEvaluacion
    {
        public int IdGrillaTema { get; set; }
        public string Nombre { get; set; } = string.Empty;
        public decimal Ponderacion { get; set; }
        public int Orden { get; set; }
        public List<GrillaSubtemaDTO> Subtemas { get; set; } = new();
        public decimal ProgresoCompletitud { get; set; }
    }

    // Propiedades calculadas
    private decimal progresoTotal => temasBinarizados.Count > 0
        ? temasBinarizados.Average(t => t.ProgresoCompletitud)
        : 0;

    private int subtemasCargados => conocimientos.Count(c => c.ValorFuncional > 0 || c.ValorTecnico > 0);
    private int totalSubtemas => grillaSubtemas.Count;

    protected override async Task OnInitializedAsync()
    {
        await VerificarPermisos();
        await CargarDatos();
    }

    private async Task VerificarPermisos()
    {
        try
        {
            // Verificar si el usuario actual es el dueńo de la evaluación
            var usuarioActual = AuthState.GetCurrentUserId();
            esRecursoDueńo = usuarioActual == IdRecurso;

            // Verificar si el usuario actual es supervisor del recurso evaluado
            if (!esRecursoDueńo && AuthState.CanSupervise())
            {
                esSupervisor = await RecursoSupervisorClient.ExisteRelacionAsync(usuarioActual, IdRecurso);
                Console.WriteLine($"Usuario {usuarioActual} es supervisor de {IdRecurso}: {esSupervisor}");
            }

