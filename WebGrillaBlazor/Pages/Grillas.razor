@page "/grillas"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.ApiClient
@using WebGrillaBlazor.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web
@inject ApiClientGeneric<GrillaDTO> ApiClient
@inject AuthStateService AuthState
@inject NavigationManager Navigation

<PageTitle>Gestión de Grillas</PageTitle>

<WebGrillaBlazor.Components.AuthorizeView RedirectToLogin="true">
    @if (!AuthState.UserCanAccess("GRILLAS"))
    {
        <div class="alert alert-danger">
            <h4 class="alert-heading">Acceso Denegado</h4>
            <p>No tienes permisos para acceder a la gestión de grillas.</p>
            <hr>
            <p class="mb-0">
                <strong>Permisos requeridos:</strong> GRILLAS_READ<br>
                <strong>Tu rol actual:</strong> @AuthState.CurrentUser?.NombreRol<br>
                Contacta con un administrador si necesitas acceso a esta funcionalidad.
            </p>
            <div class="mt-3">
                <button class="btn btn-primary" @onclick="@(() => Navigation.NavigateTo("/index"))">
                    <Icon Name="IconName.ArrowLeft" class="me-1" />
                    Volver al Dashboard
                </button>
            </div>
        </div>
        return;
    }

    <div class="container-fluid">
        <div class="row mb-3">
            <div class="col">
                <h3>
                    <Icon Name="IconName.Grid" class="me-2 text-primary" />
                    Gestión de Grillas
                </h3>
                <p class="text-muted">Configurar y administrar grillas con temas y subtemas para estructurar las evaluaciones</p>
            </div>
            <div class="col-auto">
                @if (AuthState.UserHasPermission("GRILLAS_WRITE"))
                {
                    <Button Color="ButtonColor.Success" Size="ButtonSize.Small" @onclick="AddGrilla">
                        <Icon Name="IconName.Plus" class="me-1" />
                        Agregar Grilla
                    </Button>
                }
                else
                {
                    <Button Color="ButtonColor.Secondary" Size="ButtonSize.Small" disabled title="Sin permisos de escritura">
                        <Icon Name="IconName.Lock" class="me-1" />
                        Sin permisos
                    </Button>
                }
            </div>
        </div>

        <!-- Grilla de Grillas -->
        <div class="card">
            <div class="card-body">
                <Grid @ref="gridGrilla"
                      TItem="GrillaDTO"
                      Class="table table-hover table-bordered table-striped"
                      DataProvider="GetAllGrillas"
                      AllowPaging="true"
                      PageSize="5"
                      AllowSorting="true"
                      AllowRowClick="true"
                      OnRowClick="OnRowClick"
                      OnRowDoubleClick="OnGrillaDobleClick"
                      Responsive="true">
                    <GridColumns>
                        <GridColumn TItem="GrillaDTO" HeaderText="ID" PropertyName="IdGrilla" SortKeySelector="item => item.IdGrilla">
                            @context.IdGrilla
                        </GridColumn>
                        <GridColumn TItem="GrillaDTO" HeaderText="Nombre" PropertyName="Nombre" SortKeySelector="item => item.Nombre">
                            @context.Nombre
                        </GridColumn>
                        <GridColumn TItem="GrillaDTO" HeaderText="Descripción" PropertyName="Descripcion" SortKeySelector="item => item.Descripcion">
                            @context.Descripcion
                        </GridColumn>
                        <GridColumn TItem="GrillaDTO" HeaderText="Fecha Vigencia" PropertyName="FechaVigencia" SortKeySelector="item => item.FechaVigencia">
                            @context.FechaVigencia.ToString("dd-MM-yyyy")
                        </GridColumn>
                        <GridColumn TItem="GrillaDTO" HeaderText="Estado" PropertyName="Estado" SortKeySelector="item => item.Estado">
                            @GetEstadoGrilla(context)
                        </GridColumn>
                        <GridColumn TItem="GrillaDTO" HeaderText="Acciones">
                            <div class="d-flex gap-1">
                                <a href="@($"/grillas/{@context.IdGrilla}/temas")" 
                                   class="btn btn-info btn-sm" 
                                   title="Ver temas">
                                    <Icon Name="IconName.Eye" />
                                </a>
                                @if (AuthState.UserHasPermission("GRILLAS_WRITE"))
                                {
                                    <Button Color="ButtonColor.Primary" 
                                            Size="ButtonSize.ExtraSmall" 
                                            @onclick="() => EditarGrilla(context)"
                                            title="Editar grilla">
                                        <Icon Name="IconName.Pencil" />
                                    </Button>
                                }
                            </div>
                        </GridColumn>
                    </GridColumns>
                </Grid>
            </div>
        </div>

        <!-- Información de grilla seleccionada -->
        <div class="row mt-4">
            <div class="col-12">
                <div class="card">
                    <div class="card-body">
                        <h6 class="card-title">
                            <Icon Name="IconName.InfoCircle" class="me-2" />
                            Grilla Seleccionada
                        </h6>
                        @if (currentIdGrilla == 0)
                        {
                            <p class="text-muted mb-0">No hay grilla seleccionada</p>
                        }
                        else
                        {
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <strong>@(selectedGrilla?.Nombre ?? "Cargando...")</strong>
                                    <p class="mb-0 text-muted">@(selectedGrilla?.Descripcion ?? "")</p>
                                </div>
                                @if (AuthState.UserHasPermission("GRILLAS_READ") && currentIdGrilla > 0)
                                {
                                    <a href="@($"/grillas/{currentIdGrilla}/temas")" class="btn btn-outline-primary btn-sm">
                                        <Icon Name="IconName.List" class="me-1" />
                                        Ver Temas
                                    </a>
                                }
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Ficha Edicion Grilla -->
        <Modal @ref="_EdicionGrilla" UseStaticBackdrop="true" CloseOnEscape="false" Size="ModalSize.Large" />
        
        <!-- Información adicional para usuarios sin permisos de escritura -->
        @if (!AuthState.UserHasPermission("GRILLAS_WRITE"))
        {
            <div class="alert alert-info mt-3">
                <Icon Name="IconName.InfoCircle" class="me-2" />
                <strong>Modo solo lectura:</strong> Puedes consultar las grillas y ver sus temas, pero no realizar modificaciones.
            </div>
        }
    </div>
</WebGrillaBlazor.Components.AuthorizeView>

@code {
    private IEnumerable<GrillaDTO> grillas = default!;
    private int currentIdGrilla = 0;
    private Modal _EdicionGrilla = default!;
    private Grid<GrillaDTO> gridGrilla = default!;
    private GrillaDTO selectedGrilla = new();

    protected override async Task OnInitializedAsync()
    {
        Console.WriteLine("Grillas: Inicializando página...");
        Console.WriteLine($"   - Usuario: {AuthState.CurrentUser?.NombreCompleto}");
        Console.WriteLine($"   - Puede acceder: {AuthState.UserCanAccess("GRILLAS")}");
        Console.WriteLine($"   - Permisos escritura: {AuthState.UserHasPermission("GRILLAS_WRITE")}");

        await base.OnInitializedAsync();
    }

    private async Task<GridDataProviderResult<GrillaDTO>> GetAllGrillas(GridDataProviderRequest<GrillaDTO> request)
    {
        Console.WriteLine("GetAllGrillas");

        if (grillas is null) // pull grillas only one time for client-side filtering, sorting, and paging
            grillas = await ApiClient.GetAllAsync(); // call a service or an API to pull the grillas

        return await Task.FromResult(request.ApplyTo(grillas));
    }

    private async Task AddGrilla()
    {
        if (!AuthState.UserHasPermission("GRILLAS_WRITE"))
        {
            Console.WriteLine("Sin permisos para crear grilla");
            return;
        }

        try
        {
            var nuevo = CreateGrilla();
            
            // Guardar en la base de datos a través de la API
            var grillaGuardada = await ApiClient.CreateAsync(nuevo);
            
            // Refrescar la lista desde la base de datos
            grillas = null; // Limpiar caché para forzar recarga
            await gridGrilla.RefreshDataAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al agregar grilla: {ex.Message}");
            // Aquí podrías mostrar un mensaje de error al usuario
        }
    }

    private GrillaDTO CreateGrilla()
    {
        // No asignar ID manualmente, dejar que la base de datos lo genere
        var nuevo = new GrillaDTO();
        
        nuevo.IdGrilla = 0; // La base de datos asignará el ID
        nuevo.Nombre = $"Nueva Grilla {DateTime.Now:yyyyMMdd-HHmmss}";
        nuevo.Descripcion = $"Descripción de nueva grilla";
        nuevo.FechaVigencia = DateTime.Today;
        nuevo.Estado = 1; // inactiva

        return nuevo;
    }

    private async Task EditarGrilla(GrillaDTO grilla)
    {
        if (!AuthState.UserHasPermission("GRILLAS_WRITE"))
        {
            Console.WriteLine("Sin permisos para editar grilla");
            return;
        }
        
        var param = new Dictionary<string, object>();
        param.Add("OnClickCallback", EventCallback.Factory.Create<MouseEventArgs>(this, OnCloseModalEdicionGrilla));
        param.Add("grilla", grilla);
        await _EdicionGrilla.ShowAsync<FichaGrilla>(title: "Edición Grilla", parameters: param);
    }

    private async Task OnGrillaDobleClick(GridRowEventArgs<GrillaDTO> args)
    {
        if (!AuthState.UserHasPermission("GRILLAS_WRITE"))
        {
            Console.WriteLine("Sin permisos para editar grilla - doble click ignorado");
            return;
        }
        
        Console.WriteLine("Evento OnGrillaDobleClick");
        var param = new Dictionary<string, object>();
        param.Add("OnClickCallback", EventCallback.Factory.Create<MouseEventArgs>(this, OnCloseModalEdicionGrilla));
        param.Add("grilla", args.Item);
        // Especifico el tipo del componente que quiero mostrar en el modal
        await _EdicionGrilla.ShowAsync<FichaGrilla>(title: "Edición Grilla", parameters: param);
    }

    private async Task OnCloseModalEdicionGrilla()
    {
        Console.WriteLine("OnCloseModalEdicionGrilla()");
        await _EdicionGrilla.HideAsync(); // Ocultar el formulario de Edicion
        await RefreshGrid(); // Refrescar la grilla
    }

    private async Task RefreshGrid()
    {
        grillas = null; // Limpiar la caché local de grillas
        await gridGrilla.RefreshDataAsync();
        StateHasChanged(); // Forzar la actualización de la grilla
    }

    private async Task OnRowClick(GridRowEventArgs<GrillaDTO> args)
    {
        Console.WriteLine($"OnRowClick Grilla current: {currentIdGrilla} nuevo: {args.Item.IdGrilla} ");
        currentIdGrilla = args.Item.IdGrilla;
        
        try
        {
            selectedGrilla = await ApiClient.GetByIdAsync(currentIdGrilla);
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al obtener grilla {currentIdGrilla}: {ex.Message}");
            selectedGrilla = new GrillaDTO { Descripcion = "Error al cargar" };
        }
        
        StateHasChanged(); // Forzar actualización de la UI
    }

    private string GetEstadoGrilla(GrillaDTO grilla)
    {
        // Si la fecha de vigencia es mayor o igual a hoy, está vigente
        if (grilla.FechaVigencia >= DateTime.Today)
            return "Vigente";
        else
            return "No vigente";
    }
}
