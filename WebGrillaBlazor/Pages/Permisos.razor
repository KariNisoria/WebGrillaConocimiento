@page "/permisos"
@using WebGrillaBlazor.DTOs
@using WebGrillaBlazor.Services
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

<PageTitle>Administraciµn de Permisos</PageTitle>

<WebGrillaBlazor.Components.AuthorizeView RedirectToLogin="true">
    @if (!AuthState.UserHasPermission("PERMISOS_ADMIN"))
    {
        <div class="alert alert-danger">
            <h4 class="alert-heading">? Acceso Denegado</h4>
            <p>No tienes permisos para administrar los permisos del sistema.</p>
            <hr>
            <p class="mb-0">Contacta con un administrador si necesitas acceso a esta funcionalidad.</p>
        </div>
        return;
    }

    <div class="container-fluid">
        <div class="row">
            <div class="col-12">
                <div class="card">
                    <div class="card-header bg-primary text-white">
                        <h4 class="card-title mb-0">
                            <Icon Name="IconName.Shield" class="me-2" />
                            Administraciµn de Permisos por Rol
                        </h4>
                    </div>
                    <div class="card-body">
                        
                        <!-- Informaciµn del sistema actual -->
                        <div class="alert alert-info">
                            <h6 class="alert-heading">
                                <Icon Name="IconName.InfoCircle" class="me-2" />
                                Estado del Sistema de Permisos
                            </h6>
                            <div class="row">
                                <div class="col-md-6">
                                    <p class="mb-1"><strong>Total de roles:</strong> @totalRoles</p>
                                    <p class="mb-1"><strong>Total de permisos configurados:</strong> @totalPermisos</p>
                                </div>
                                <div class="col-md-6">
                                    <p class="mb-1"><strong>Öltima actualizaciµn:</strong> @fechaUltimaActualizacion</p>
                                    <p class="mb-0"><strong>Sistema:</strong> Base de datos + Fallback</p>
                                </div>
                            </div>
                        </div>

                        <!-- Botones de acciµn -->
                        <div class="mb-4">
                            <button class="btn btn-success me-2" @onclick="CargarPermisos">
                                <Icon Name="IconName.ArrowClockwise" class="me-1" />
                                Recargar Datos
                            </button>
                            <button class="btn btn-warning me-2" @onclick="() => showConfiguracionInicial = true">
                                <Icon Name="IconName.Gear" class="me-1" />
                                Configuraciµn Inicial
                            </button>
                            <button class="btn btn-info" @onclick="() => showAyuda = !showAyuda">
                                <Icon Name="IconName.QuestionCircle" class="me-1" />
                                @(showAyuda ? "Ocultar" : "Mostrar") Ayuda
                            </button>
                        </div>

                        <!-- Panel de ayuda -->
                        @if (showAyuda)
                        {
                            <div class="alert alert-secondary">
                                <h6>?? GuÚa de Permisos</h6>
                                <div class="row">
                                    <div class="col-md-6">
                                        <p><strong>Estructura de permisos:</strong></p>
                                        <ul class="small">
                                            <li><code>MODULO_READ</code> - Consultar/Ver</li>
                                            <li><code>MODULO_WRITE</code> - Crear/Editar</li>
                                            <li><code>MODULO_DELETE</code> - Eliminar</li>
                                        </ul>
                                    </div>
                                    <div class="col-md-6">
                                        <p><strong>Mµdulos disponibles:</strong></p>
                                        <ul class="small">
                                            <li>RECURSOS, ROLES, GRILLAS, TEMAS, SUBTEMAS</li>
                                            <li>EVALUACIONES, CLIENTES, EQUIPOS, TIPOS_DOCUMENTO</li>
                                            <li>SUPERVISION, EVALUACIONES_GLOBALES</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        }

                        <!-- Configuraciµn inicial -->
                        @if (showConfiguracionInicial)
                        {
                            <div class="alert alert-warning">
                                <h6 class="alert-heading">?? Configuraciµn Inicial del Sistema</h6>
                                <p>Para configurar los permisos iniciales, ejecuta el siguiente script SQL:</p>
                                <div class="bg-dark text-white p-3 rounded">
                                    <code>Scripts/06_CrearTablaRolPermisos.sql</code>
                                </div>
                                <div class="mt-3">
                                    <button class="btn btn-outline-secondary btn-sm me-2" @onclick="() => showConfiguracionInicial = false">
                                        Cerrar
                                    </button>
                                    <button class="btn btn-outline-primary btn-sm" @onclick="CopiarRutaScript">
                                        Copiar Ruta
                                    </button>
                                </div>
                            </div>
                        }

                        <!-- Tabla de permisos por rol -->
                        <div class="table-responsive">
                            <table class="table table-striped table-hover">
                                <thead class="table-dark">
                                    <tr>
                                        <th>Rol</th>
                                        <th>Permisos Configurados</th>
                                        <th>Estado</th>
                                        <th>Acciones</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>
                                            <strong>Administrador</strong>
                                            <br><small class="text-muted">Acceso completo al sistema</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-success">Todos los mµdulos</span>
                                            <br><small>READ, WRITE, DELETE en todos los mµdulos + SUPERVISION</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-success">Configurado</span>
                                        </td>
                                        <td>
                                            <button class="btn btn-outline-primary btn-sm" disabled>
                                                Ver Detalles
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Manager</strong>
                                            <br><small class="text-muted">Gestiµn sin eliminaciones crÚticas</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-info">Gestiµn</span>
                                            <br><small>READ/WRITE en la mayorÚa, READ en roles y equipos + SUPERVISION</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-success">Configurado</span>
                                        </td>
                                        <td>
                                            <button class="btn btn-outline-primary btn-sm" disabled>
                                                Ver Detalles
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Evaluador</strong>
                                            <br><small class="text-muted">Enfocado en evaluaciones</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-warning">Evaluaciones</span>
                                            <br><small>READ/WRITE solo en evaluaciones, READ en otros</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-success">Configurado</span>
                                        </td>
                                        <td>
                                            <button class="btn btn-outline-primary btn-sm" disabled>
                                                Ver Detalles
                                            </button>
                                        </td>
                                    </tr>
                                    <tr>
                                        <td>
                                            <strong>Desarrollador</strong>
                                            <br><small class="text-muted">Solo consultas bÃsicas</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-secondary">Solo lectura</span>
                                            <br><small>READ en mµdulos bÃsicos</small>
                                        </td>
                                        <td>
                                            <span class="badge bg-success">Configurado</span>
                                        </td>
                                        <td>
                                            <button class="btn btn-outline-primary btn-sm" disabled>
                                                Ver Detalles
                                            </button>
                                        </td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <!-- Nota informativa -->
                        <div class="alert alert-light mt-4">
                            <Icon Name="IconName.InfoCircle" class="me-2" />
                            <strong>Nota:</strong> Para configuraciones avanzadas de permisos, utiliza la pÃgina de 
                            <a href="/admin/permisos-roles" class="alert-link">Configuraciµn de Permisos</a> 
                            donde puedes gestionar los permisos de forma detallada.
                        </div>

                    </div>
                </div>
            </div>
        </div>
    </div>
</WebGrillaBlazor.Components.AuthorizeView>

@code {
    private bool showAyuda = false;
    private bool showConfiguracionInicial = false;
    private int totalRoles = 4;
    private int totalPermisos = 0;
    private string fechaUltimaActualizacion = "Por configurar";

    protected override async Task OnInitializedAsync()
    {
        await AuthState.InitializeAsync();
        await CargarPermisos();
    }

    private async Task CargarPermisos()
    {
        // Simular carga de datos
        // En un escenario real, aquÚ harÚas llamadas a la API para obtener estadÚsticas
        await Task.Delay(500);
        
        totalRoles = 4; // Admin, Manager, Evaluador, Desarrollador
        totalPermisos = 55; // Estimado basado en el script + supervision
        fechaUltimaActualizacion = DateTime.Now.ToString("yyyy-MM-dd HH:mm");
        
        StateHasChanged();
    }

    private async Task CopiarRutaScript()
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", "Scripts/06_CrearTablaRolPermisos.sql");
        // Mostrar notificaciµn (puedes agregar un toast aquÚ)
    }
}