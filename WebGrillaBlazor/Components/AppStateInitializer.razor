@using WebGrillaBlazor.Services
@inject AuthStateService AuthState
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime

@if (isInitialized)
{
    @ChildContent
    
    <!-- Panel de diagnÛstico temporal (remover en producciÛn) -->
    @if (showDiagnostics)
    {
        <WebGrillaBlazor.Components.DiagnosticPanel />
    }
}
else
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);">
        <div class="text-center text-white">
            <div class="mb-4">
                <div class="spinner-border text-light" role="status" style="width: 4rem; height: 4rem;">
                    <span class="visually-hidden">Cargando...</span>
                </div>
            </div>
            <div>
                <h3 class="fw-light">?? Sistema de Grillas de Conocimiento</h3>
                <p class="mb-0 opacity-75">@loadingMessage</p>
                @if (hasError)
                {
                    <div class="alert alert-warning mt-3 d-inline-block">
                        <small>@errorMessage</small>
                        <br>
                        <button class="btn btn-sm btn-outline-warning mt-2" @onclick="RetryInitialization">
                            ?? Reintentar
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    
    private bool isInitialized = false;
    private string loadingMessage = "Inicializando aplicaciÛn...";
    private bool hasError = false;
    private string errorMessage = "";
    private bool showDiagnostics = true; // Cambiar a false en producciÛn

    protected override async Task OnInitializedAsync()
    {
        await InitializeApp();
    }

    private async Task InitializeApp()
    {
        try
        {
            hasError = false;
            errorMessage = "";
            
            Console.WriteLine("?? === INICIANDO APLICACI”N ===");
            
            // Obtener ruta actual ANTES de hacer cualquier operaciÛn
            var currentUri = new Uri(Navigation.Uri);
            var currentPath = currentUri.AbsolutePath.ToLower();
            
            Console.WriteLine($"?? AppStateInitializer - Ruta actual: {currentPath}");
            
            loadingMessage = "Verificando JavaScript Runtime...";
            StateHasChanged();
            
            // Esperar que JSRuntime estÈ completamente disponible
            await Task.Delay(300);
            
            // PASO 1: Inicializar AuthState SIEMPRE (esto cargar· datos de localStorage si existen)
            loadingMessage = "Inicializando sistema de autenticaciÛn...";
            StateHasChanged();
            await AuthState.InitializeAsync();
            
            // Verificar el estado actual despuÈs de la inicializaciÛn
            Console.WriteLine($"?? Estado despuÈs de InitializeAsync:");
            Console.WriteLine($"   - IsAuthenticated: {AuthState.IsAuthenticated}");
            Console.WriteLine($"   - CurrentUser: {AuthState.CurrentUser?.NombreCompleto ?? "null"}");
            Console.WriteLine($"   - Ruta: {currentPath}");
            
            // PASO 2: SOLO limpiar sesiÛn si estamos en la p·gina de login Y queremos limpiar explÌcitamente
            if (currentPath == "/" && !AuthState.IsAuthenticated)
            {
                loadingMessage = "Preparando p·gina de login...";
                StateHasChanged();
                
                Console.WriteLine("?? En p·gina de login sin usuario - preparando formulario");
                // NO limpiar localStorage aquÌ, ya que InitializeAsync maneja la carga
            }
            else if (currentPath == "/" && AuthState.IsAuthenticated)
            {
                Console.WriteLine("? Usuario ya autenticado en p·gina de login - proceder a redirecciÛn");
            }
            else if (currentPath != "/" && AuthState.IsAuthenticated)
            {
                Console.WriteLine($"? Usuario autenticado en ruta protegida '{currentPath}' - todo OK");
            }
            else if (currentPath != "/" && !AuthState.IsAuthenticated)
            {
                Console.WriteLine($"?? Acceso a ruta protegida '{currentPath}' sin autenticaciÛn - requerir· redirecciÛn");
            }
            
            loadingMessage = "Configurando navegaciÛn...";
            StateHasChanged();
            
            // PASO 3: Manejar navegaciÛn seg˙n el estado actual
            await HandleNavigationLogic();
            
            Console.WriteLine($"? Estado final AppStateInitializer:");
            Console.WriteLine($"   - Autenticado: {AuthState.IsAuthenticated}");
            Console.WriteLine($"   - Ruta: {currentPath}");
            Console.WriteLine($"   - Usuario: {AuthState.CurrentUser?.NombreCompleto ?? "null"}");
            
        }
        catch (Exception ex)
        {
            Console.WriteLine($"? Error inicializando aplicaciÛn: {ex.Message}");
            Console.WriteLine($"? Stack trace: {ex.StackTrace}");
            hasError = true;
            errorMessage = $"Error al inicializar: {ex.Message}";
            StateHasChanged();
            return;
        }
        
        // Marcar como inicializado solo si no hay errores
        loadingMessage = "°AplicaciÛn lista!";
        isInitialized = true;
        StateHasChanged();
    }

    private async Task RetryInitialization()
    {
        isInitialized = false;
        await InitializeApp();
    }

    private async Task HandleNavigationLogic()
    {
        var currentUri = new Uri(Navigation.Uri);
        var currentPath = currentUri.AbsolutePath.ToLower();
        
        Console.WriteLine($"?? === EVALUANDO NAVEGACI”N ===");
        Console.WriteLine($"?? Ruta actual: '{currentPath}'");
        Console.WriteLine($"?? Est· autenticado: {AuthState.IsAuthenticated}");
        Console.WriteLine($"?? Usuario actual: {AuthState.CurrentUser?.NombreCompleto ?? "null"}");
        
        // REGLA 1: Si est· en una ruta protegida Y NO est· autenticado ? ir al login
        if (currentPath != "/" && !AuthState.IsAuthenticated)
        {
            Console.WriteLine("?? REGLA 1: Ruta protegida sin autenticaciÛn ? Redirigir a login");
            loadingMessage = "Acceso denegado - Redirigiendo al login...";
            StateHasChanged();
            await Task.Delay(1000); // Pausa para debug
            Navigation.NavigateTo("/", forceLoad: false);
            return;
        }
        
        // REGLA 2: Si est· en login Y YA est· autenticado ? ir al dashboard  
        if (currentPath == "/" && AuthState.IsAuthenticated)
        {
            Console.WriteLine("?? REGLA 2: En login pero ya autenticado ? Redirigir a dashboard");
            loadingMessage = "Ya autenticado - Redirigiendo al dashboard...";
            StateHasChanged();
            await Task.Delay(1000); // Pausa para debug
            Navigation.NavigateTo("/index", forceLoad: false);
            return;
        }
        
        // REGLA 3: Si est· en ruta v·lida Y autenticado ? todo OK
        if (currentPath != "/" && AuthState.IsAuthenticated)
        {
            Console.WriteLine("? REGLA 3: En ruta protegida y autenticado ? Todo OK");
            return;
        }
        
        // REGLA 4: Si est· en login Y NO autenticado ? todo OK (mostrar login)
        if (currentPath == "/" && !AuthState.IsAuthenticated)
        {
            Console.WriteLine("? REGLA 4: En login y no autenticado ? Mostrar formulario de login");
            return;
        }
        
        // Si llegamos aquÌ, hay un estado no contemplado
        Console.WriteLine($"?? ESTADO NO CONTEMPLADO:");
        Console.WriteLine($"   - Ruta: '{currentPath}'");
        Console.WriteLine($"   - Autenticado: {AuthState.IsAuthenticated}");
        Console.WriteLine($"   - AcciÛn: Ninguna (mantener estado actual)");
    }
}