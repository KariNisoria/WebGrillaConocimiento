@using WebGrillaBlazor.Services
@inject AuthStateService AuthState
@inject NavigationManager Navigation

@if (isInitialized)
{
    @ChildContent
}
else
{
    <div class="d-flex justify-content-center align-items-center" style="height: 100vh;">
        <div class="text-center">
            <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                <span class="visually-hidden">Cargando...</span>
            </div>
            <div class="mt-3">
                <h5>Inicializando aplicaciÛn...</h5>
                <p class="text-muted">Verificando estado de autenticaciÛn</p>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public RenderFragment? ChildContent { get; set; }
    
    private bool isInitialized = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Inicializar estado de autenticaciÛn
            await AuthState.InitializeAsync();
            
            // Verificar si estamos en la ruta raÌz y no hay autenticaciÛn
            var currentUri = new Uri(Navigation.Uri);
            var isRootPath = currentUri.AbsolutePath == "/";
            
            if (isRootPath && !AuthState.IsAuthenticated)
            {
                // Redirigir al login si estamos en la p·gina principal y no hay autenticaciÛn
                Navigation.NavigateTo("/login", forceLoad: false);
                return;
            }
            
            // Marcar como inicializado
            isInitialized = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error inicializando aplicaciÛn: {ex.Message}");
            // En caso de error, permitir continuar pero probablemente sin autenticaciÛn
            isInitialized = true;
            StateHasChanged();
        }
    }
}